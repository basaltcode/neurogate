    model: "@cf/meta/llama-3.3-70b-instruct-fp8-fast"
    api_key_env: CLOUDFLARE_API_KEY
    rpd: 300
    timeout: 120   # FP8 bulk медленный: v2 бенч 18s total
    quality: 14   # AA Index v4.0 (FP8 penalty)
    latency_s: 17.941
    ru: 65        # bench: 13/20 (auto, 1.32s avg)

  # --- Cloudflare WAI extras (2026-05-13, awesome-free-llm-apis) ---
