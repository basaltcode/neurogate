# neurogate — full reference config (example).
#
# Quick start:
#   1. cp config.yaml.example config.yaml
#   2. Удали из config.yaml те провайдеры/chains, которые тебе не нужны.
#   3. Заполни ключи в .env (гайд по получению — docs/providers-setup.md).
#   4. Запусти: uv sync && uv run neurogate
#
# Без ключа провайдер автоматически пропускается на старте — можно начать с
# одного бесплатного ключа (например, Groq) и расширять по необходимости. Если
# в chain не осталось ни одного работающего провайдера, сервер откажется
# стартовать и подскажет какие env-vars выставить.
#
# Структура: провайдеры определяются один раз в `providers:` (упорядочены по
# default-цепочке chat, reasoning-only — в конце). Цепочки в `chains:`
# ссылаются по имени. Клиент выбирает цепочку через поле `model` в запросе:
#   model: "chat"       → цепочка chat (default, русский приоритет)
#   model: "chat_fast"  → chat без моделей с latency > 5s (отсечены «долгодумы»)
#   model: "chat_en"    → английский чат, AA Index v4.0
#   model: "code"       → reasoning + SWE/LCB composite
#   model: "latency"    → по медианам Total time (быстрее сверху)
#   model: "quality"    → AA Intelligence Index v4.0
#   model: "unlimited"  → провайдеры без RPD-кэпа (для high-volume)
#   model: "image"      → vision-capable, порядок по точности описаний
#   model: "reasoning_quality" → thinking-модели по AA Index
#   model: "reasoning_deep" → thinking-модели по глубине thinking
#   model: "paid"       → единственная платная (Claude Opus через OpenRouter)
#   model: "web"        → OpenRouter :online провайдеры с веб-поиском (Exa)
#   model: "translation" → мультиязычные (Qwen 119 langs, Mistral, Gemma 140 langs)
#   model: "moa"        → Mixture of Agents: параллельные proposers + aggregator
#   model: "sc"         → Self-Consistency: N сэмплов от одной модели + aggregator (?samples=N)
#   model: "deep_search" → Research-агент: plan→search→synthesize→critique (?max_subq=N&rounds=R)
#   model: "tts"        → Text-to-Speech через /v1/audio/speech (Edge TTS, безлимит)
#   model: "auto"       → default_chain
#   любое другое        → default_chain
#
# Все model-IDs проверены через /v1/chat/completions (HTTP 200) или в каталоге
# моделей провайдера на момент срезы конфигурации. Часть моделей быстро
# протухает — если что-то стало 404, провайдер выпадет из chain автоматически.

providers:
  # === quality = AA Intelligence Index v4.0 (deepchain1, 16.12.2025) ===
  # === latency_s = медиана Total time из LATENCY_TEST_v2_default.md (Hetzner FSN1 → upstream, 2026-04-20, max_tokens=600) ===
  # === ru = RU-Quality 0-100: грамматика + корректность физики + следование инструкции (v2_default/instruct 2026-04-20). Пороги: ≥80 top, ≥60 strong, ≥40 mid, <40 low. ===

  # === DeepSeek direct API (api.deepseek.com) — V4 Preview, релиз 2026-04-24 ===
  # ⚠️ ПЛАТНЫЙ PAYG. Регистрационного гранта 5M НЕТ (проверено 2026-05-12 на новом аккаунте:
  # HTTP 402 "Insufficient Balance" сразу). Минимальный top-up $2 на platform.deepseek.com.
  # V4-Pro: 1.6T/49B active, SWE-V 80.6%, Codeforces 3206 — frontier coding.
  # V4-Flash: 284B/13B active, для быстрых ответов. Оба — 1M context.
  # Цены (со скидкой 75% до 2026-05-31): Pro $0.435/$0.87, Flash $0.14/$0.28 за 1M.
  # Подключены только в chain `paid` — не катаются в chat/code/quality, чтобы не сжечь баланс.
  - name: deepseek:v4-pro
    kind: deepseek
    model: deepseek-v4-pro
    api_key_env: DEEPSEEK_API_KEY
    quota_limited: true   # 💳 PAYG (как openrouter:claude-opus-4.7)
    timeout: 240          # reasoning может занимать долго
    quality: 80           # AA Index v4.0 (frontier-class, SWE-V 80.6% ≈ Opus 4.6)
    latency_s: 5.0        # estimate — reasoning, прогнать live-probe
    ru: 85                # estimate (DeepSeek сильна в RU, V3.2 = 85)
    reasoning: true

  - name: deepseek:v4-flash
    kind: deepseek
    model: deepseek-v4-flash
    api_key_env: DEEPSEEK_API_KEY
    quota_limited: true   # 💳 PAYG, общий баланс с v4-pro
    timeout: 120
    quality: 50           # estimate — между V3.2 (46) и V4-Pro (80)
    latency_s: 2.5        # estimate, non-reasoning fast
    ru: 80                # estimate

  - name: sambanova:deepseek-v3.2
    kind: sambanova
    model: DeepSeek-V3.2
    api_key_env: SAMBANOVA_API_KEY
    rpd: 20  # per-model bucket (проверено через x-ratelimit-limit-requests-day)
    quality: 46   # AA Index v4.0 (reasoning)
    latency_s: 3.448
    ru: 85        # bench: 17/20 (auto, 1.92s avg)

  - name: mistral:large
    kind: mistral
    model: mistral-large-latest
    api_key_env: MISTRAL_API_KEY
    rpm: 4  # Experiment plan: хедер x-ratelimit-limit-req-minute=4 (не 60 как в старых доках)
    # ⚠️ Privacy: opt-out в console.mistral.ai → Admin → Privacy → "Anonymous improvement data" = OFF
    quality: 23   # AA Index v4.0 (Mistral Large 3)
    latency_s: 11.884
    ru: 75        # bench: 15/20 (auto, 1.59s avg)

  - name: nvidia:qwen3.5-397b
    kind: nvidia
    model: qwen/qwen3.5-397b-a17b
    api_key_env: NVIDIA_API_KEY
    rpm: 40  # NVIDIA NIM: без RPD, только per-model ~40 RPM (хедеры не отдаются)
    timeout: 240   # медленный NIM endpoint: 2026-04-21 повтор бенча — 219s для 779ch output
    # 397B MoE с 17B active parameters. SWE-b V 76.4%, сильный multilingual+RU.
    # Instruct-вариант (не thinking): API не возвращает reasoning_content/<think> — подтверждено 2026-04-21.
    quality: 40   # AA Index v4.0 (Feb 2026, non-reasoning)
    latency_s: 71.904
    ru: 75        # bench: 15/20 (auto, 23.75s avg)

  - name: nvidia:qwen3-coder-480b
    kind: nvidia
    model: qwen/qwen3-coder-480b-a35b-instruct
    api_key_env: NVIDIA_API_KEY
    rpm: 40
    timeout: 240
    # 480B MoE / 35B active, 256k ctx, agentic coding. Identity verified 2026-05-02.
    quality: 32   # estimate 2026-05-02 (extrap из бенчей Qwen3-Coder)
    latency_s: 5.0  # estimate
    ru: 70         # estimate

  - name: nvidia:minimax-m2.7
    kind: nvidia
    model: minimaxai/minimax-m2.7
    api_key_env: NVIDIA_API_KEY
    rpm: 40
    timeout: 240
    quality: 30   # estimate 2026-05-02 (230B coding/reasoning, identity verified)
    latency_s: 6.0
    ru: 75        # estimate
    reasoning: true  # 2026-05-02: reasoning_content=561 при max_tokens=300

  - name: nvidia:step-3.5-flash
    kind: nvidia
    model: stepfun-ai/step-3.5-flash
    api_key_env: NVIDIA_API_KEY
    rpm: 40
    timeout: 240
    quality: 26   # estimate 2026-05-02 (200B MoE reasoning, StepFun)
    latency_s: 6.0
    ru: 70        # estimate
    reasoning: true  # 2026-05-02: reasoning_content=270 при max_tokens=300

  - name: nvidia:seed-oss-36b
    kind: nvidia
    model: bytedance/seed-oss-36b-instruct
    api_key_env: NVIDIA_API_KEY
    rpm: 40
    timeout: 240
    quality: 22   # estimate 2026-05-02 (Doubao/ByteDance, long-context)
    latency_s: 5.0
    ru: 65        # estimate
    reasoning: true  # 2026-05-02: reasoning_content=359 при max_tokens=300

  - name: nvidia:gemma-4-31b-it
    kind: nvidia
    model: google/gemma-4-31b-it
    api_key_env: NVIDIA_API_KEY
    rpm: 40
    timeout: 240   # smoke 2026-05-08: cold-start 95s до 200, второй вызов ~быстрее
    # backup для gemini:gemma-4-31b-it (10rpm/250rpd) — отдельный rate-limit-bucket NVIDIA NIM.
    # Smoke 2026-05-08: HTTP 200, content="OK", reasoning_tokens=0 (instruct, не thinking).
    quality: 25    # estimate (extrap из openrouter:gemma-4-31b-free / gemini:gemma-4-31b-it)
    latency_s: 95.4   # smoke cold-start 2026-05-08; переснять после warmup
    ru: 78         # estimate (extrap из gemma-4-31b-it)

  - name: sambanova:deepseek-v3.1
    kind: sambanova
    model: DeepSeek-V3.1
    api_key_env: SAMBANOVA_API_KEY
    rpd: 20
    quality: 28   # AA Index v4.0 (non-reasoning baseline)
    latency_s: 3.216
    ru: 85        # bench: 17/20 (auto, 2.25s avg)

  - name: github:deepseek-v3
    kind: github
    model: deepseek/deepseek-v3-0324
    api_key_env: GITHUB_MODELS_TOKEN
    rpm: 10
    rpd: 50
    quality: 22   # AA Index v4.0 (V3-0324)
    latency_s: 4.639   # 1/5 OK на default — flaky на длинных ответах, проверить
    ru: 45        # bench: 9/20 (auto, 0.92s avg)

  - name: openrouter:glm-4.5-air-free
    kind: openrouter
    model: z-ai/glm-4.5-air:free
    api_key_env: OPENROUTER_API_KEY
    rpm: 20
    rpd: 1000   # shared bucket на все OR :free-модели (доступно при credit ≥ $10)
    timeout: 180   # reasoning + free route: v2 бенч 98s total
    quality: 24   # AA Index v4.0 (GLM-4.5-Air reasoning)
    latency_s: 98.431
    ru: 70        # bench: 14/20 (auto, 26.57s avg)
    reasoning: true   # подтверждено 2026-04-21: reasoning_tokens=302, r_content=870ch

  - name: gemini:flash-latest
    kind: gemini
    model: gemini-flash-latest
    api_key_env: GEMINI_API_KEY
    rpm: 10
    rpd: 250
    quality: 46   # AA Index v4.0 (Gemini 3 Flash reasoning)
    latency_s: 3.582
    ru: 55        # bench: 11/20 (auto, 8.06s avg)
    reasoning: true   # подтверждено 2026-04-21: thoughts_token_count=260

  - name: gemini:2.5-flash
    kind: gemini
    model: gemini-2.5-flash
    api_key_env: GEMINI_API_KEY
    rpm: 10
    rpd: 250
    quality: 21   # AA Index v4.0 (non-reasoning в AA, но thinking включён в API)
    latency_s: 3.529   # 1/5 OK — флapping на квоте, переснять
    ru: 85        # bench: 17/20 (auto, 1.82s avg)
    reasoning: true   # подтверждено 2026-04-21: thoughts_token_count=743 (thinking включен по умолчанию)

  - name: gemini:gemma-4-31b-it
    kind: gemini
    model: gemma-4-31b-it
    api_key_env: GEMINI_API_KEY
    rpm: 10        # консервативно: Google не задокументировал явно для gemma-4-31b в free-tier — переснять при первом 429
    rpd: 250       # см. выше
    quality: 25    # estimate 2026-05-02 (extrap из openrouter:gemma-4-31b-free)
    latency_s: 2.0 # estimate (smoke ok через прямой Gemini API 2026-05-02)
    ru: 78         # estimate (extrap из openrouter:gemma-4-31b-free)

  - name: github:gpt-4.1-mini
    kind: github
    model: openai/gpt-4.1-mini
    api_key_env: GITHUB_MODELS_TOKEN
    rpm: 10
    rpd: 50
    quality: 23   # AA Index v4.0
    latency_s: 5.371
    ru: 95        # bench: 19/20 (auto, 1.72s avg)
    vision: true  # GPT-4.1-mini принимает image_url

  - name: cerebras:qwen-3-235b
    kind: cerebras
    model: qwen-3-235b-a22b-instruct-2507
    api_key_env: CEREBRAS_API_KEY
    rpm: 5      # хедер x-ratelimit-limit-requests-minute=5 (не 30)
    rpd: 14400  # per-model RPD
    quality: 30   # AA Index v4.0 (reasoning)
    latency_s: 1.098   # 4/5 OK — 429 под нагрузкой
    ru: 85        # bench: 17/20 (auto, 0.67s avg)

  - name: github:gpt-4o-mini
    kind: github
    model: openai/gpt-4o-mini
    api_key_env: GITHUB_MODELS_TOKEN
    rpm: 15
    rpd: 150
    quality: 13   # AA Index v4.0
    latency_s: 3.867
    ru: 85        # bench: 17/20 (auto, 2.81s avg)
    vision: true  # GPT-4o-mini multimodal

  - name: sambanova:llama-4-maverick
    kind: sambanova
    model: Llama-4-Maverick-17B-128E-Instruct
    api_key_env: SAMBANOVA_API_KEY
    rpd: 20
    quality: 17   # AA Index v4.0 (~)
    latency_s: 1.641
    ru: 90        # bench: 18/20 (auto, 1.98s avg)
    vision: true  # Llama 4 Maverick — native multimodal (vision input)

  - name: sambanova:llama-3.3-70b
    kind: sambanova
    model: Meta-Llama-3.3-70B-Instruct
    api_key_env: SAMBANOVA_API_KEY
    rpd: 20
    quality: 15   # AA Index v4.0 (Llama-3.3-70B baseline)
    latency_s: 4.991
    ru: 60        # bench: 12/20 (auto, 2.69s avg)

  - name: groq:llama-3.3-70b
    kind: groq
    model: llama-3.3-70b-versatile
    api_key_env: GROQ_API_KEY
    rpm: 30
