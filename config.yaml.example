  # === Audio / STT (transcription-only, только для цепочки `audio`) ===
  # Whisper на Groq — OpenAI-compat /audio/transcriptions. Бесплатный tier.
  # Бенч 2026-04-21 (test_ru.mp3, Milena TTS, 7.26s): оба Whisper ~0.6s,
  # Gemini multimodal ~3.4s. rpd — консервативная оценка (free tier Whisper
  # TPM-based, не RPD; ставим 2000 как soft-кап).
  - name: groq:whisper-large-v3-turbo
    kind: groq_whisper
    model: whisper-large-v3-turbo
    api_key_env: GROQ_API_KEY
    rpd: 2000
    latency_s: 0.62
    ru: 95   # эталонный RU, Whisper v3 turbo

  - name: groq:whisper-large-v3
    kind: groq_whisper
    model: whisper-large-v3
    api_key_env: GROQ_API_KEY
    rpd: 2000
    latency_s: 0.56
    ru: 98   # full large-v3, чуть точнее turbo


  # === TTS (text→speech, только для цепочки `tts`) ===
  # Microsoft Edge TTS — неофициальный клиент (пакет edge-tts, rany2). WebSocket
  # к speech.platform.bing.com, без API-ключа, безлимитно. 400+ голосов,
  # включая русские: ru-RU-DmitryNeural (М), ru-RU-SvetlanaNeural (Ж),
  # ru-RU-DariyaNeural (Ж). Формат — только mp3 (audio/mpeg) on-wire.
  # Voice override через поле `voice` в запросе; default задаётся здесь.
  - name: edge:tts
    kind: edge_tts
    model: edge-tts
    default_voice: ru-RU-DmitryNeural   # можно переопределить в запросе
    timeout: 60
    latency_s: 1.5   # оценка: первый аудио-чанк обычно 1-2s, зависит от длины
    ru: 85   # Neural-TTS Azure-класса; естественный RU


  # === SFX / Ambient (text→audio, только для цепочки `sfx`) ===
  # Бесплатно через публичный HuggingFace Space (gradio_client). НЕ использует
  # HF Inference API quota ($0.10/мес), но Space крутится на HF Zero-GPU →
  # анонимная per-IP квота ~3-5 минут GPU/день, каждый вызов резервирует ~120с.
  # На практике без токена помещается 1-2 вызова в сутки. С HF_TOKEN (free)
  # квота per-account и чуть выше; с HF PRO ($9/мес) — 25× квоты.
  # Раньше в цепочке были также haoheliu/audioldm2-text2audio-text2music и
  # declare-lab/tango2 — оба сейчас в HF 503 (RUNTIME_ERROR / CONFIG_ERROR на
  # стороне авторов Space). Можно вернуть, когда починятся.
  - name: hfspace:stable-audio-open
    kind: hf_space_audio
    space_id: artificialguybr/Stable-Audio-Open-Zero
    api_name: /predict
    prompt_field: prompt
    duration_field: seconds_total
    default_duration_s: 10
    api_key_env: HF_TOKEN
    timeout: 180
    quality: 70
    latency_s: 35
    ru: 50


  # === Image generation (text→image, sync, только для цепочки `image_gen`) ===
  # Pollinations — GET /prompt/{prompt} возвращает image/jpeg напрямую.
  # Провайдер оборачивает байты в OpenAI-compat {data:[{b64_json}|{url}]}.
  # Ключ передаётся как token=... (не Bearer header). Referer обязателен для
  # распознавания тира выше anonymous.
  # Tier / interval (APIDOCS.md, 2026-04-22):
  #   - anonymous: 1 req / 15s (4 rpm)
  #   - seed (registered, free с токеном): 1 req / 5s (12 rpm)   ← мы здесь
  #   - flower (paid): 1 req / 3s · nectar (enterprise): без лимитов
  # Поэтому n>1 НЕ стреляем параллельно (сервер сразу даст 429 на 3 из 4).
  # Провайдер сериализует seeds с интервалом min_interval_s и делает 1 retry
  # после 429 с бэкоффом. Rpm в 8 оставляем запасом под 12 rpm кэп seed-tier.
  - name: pollinations:sana
    kind: pollinations_image
    model: sana
    api_key_env: POLLINATIONS_API_KEY
    referer: neurogate
    rpm: 8           # seed tier = 12 rpm кэп, оставляем запас на burst
    min_interval_s: 5.0   # seed tier = 1 req / 5s (сериализация n>1 + backoff на 429)
    timeout: 90      # sana 512×512 ~1s, но при 429+retry нужен запас
    latency_s: 1.0   # измерено ~1s на 512x512 sana

  - name: pollinations:flux
    kind: pollinations_image
    model: flux
    api_key_env: POLLINATIONS_API_KEY
    referer: neurogate
    rpm: 8
    min_interval_s: 5.0
    timeout: 150     # измеренная generation latency на seed tier ~90s (очередь)
    latency_s: 90.0  # по бенчу 2026-04-22 — cached prompts <1s, uncached ~90s
    quality: 70

  - name: pollinations:turbo
    kind: pollinations_image
    model: turbo
    api_key_env: POLLINATIONS_API_KEY
    referer: neurogate
    rpm: 8
    min_interval_s: 5.0
    timeout: 150     # тот же queue pattern, что и flux на seed tier
    latency_s: 90.0
    quality: 55

  # NB: pollinations:kontext (FLUX.1 Kontext, image edit) требует enter.pollinations.ai
  # tier — на seed выдаёт HTTP 500 "only available on enter.pollinations.ai". Не добавляем.

  # === Gemini 2.5 Flash Image (Nano Banana) — generation + edit ===
  # Статус 2026-04-25: ОФИЦИАЛЬНО paid-only — это политика, не временный outage.
  # ai.google.dev/gemini-api/docs/pricing для всех image-моделей
  # (gemini-2.5-flash-image, gemini-3-pro-image-preview, gemini-3.1-flash-image-preview)
  # явно указывает «Free Tier: Not available». API возвращает 429 с
  # «limit: 0» на free_tier_input_token_count. БЕЗ billing работать не будет.
  # Провайдер оставлен только на случай включения billing на этом проекте.
  - name: gemini:nano-banana
    kind: gemini_image
    model: gemini-2.5-flash-image
    api_key_env: GEMINI_API_KEY
    timeout: 120
    rpm: 10
    rpd: 500
    latency_s: 4.0
    quality: 72

  # === Cloudflare Workers AI — FLUX-1 schnell ===
  # Permanent free: 10 000 Neurons/день (~20-50 картинок/день при 1024×1024).
  # НЕ OpenAI-compat: CloudflareImageProvider кастомно дёргает /ai/run/{model}.
  # ВАЖНО: 10 000 neurons/день — общий пул на ВЕСЬ CF-аккаунт. Добавление
  # новых cloudflare_image моделей не расширяет дневной потолок, только даёт
  # выбор по style/quality. Когда квота выжжена — все CF-провайдеры возвращают
  # 429 одновременно; нужен другой провайдер (HuggingFace, Pollinations, и т.д.).
  - name: cloudflare:flux-1-schnell
    kind: cloudflare_image
    model: "@cf/black-forest-labs/flux-1-schnell"
    api_key_env: CLOUDFLARE_API_KEY
    # account_id берётся из CLOUDFLARE_ACCOUNT_ID автоматически
    steps: 4         # schnell native step count
    timeout: 90
    latency_s: 1.1   # измерено @512×512 бенч 2026-04-22
    quality: 68

  # NB: @cf/black-forest-labs/flux-2-klein-{4b,9b} и flux-2-dev — НЕ text-to-image,
  # требуют multipart form data с input_image_0..3 (это image edit endpoint).
  # Не добавляем без отдельного провайдера/endpoint /v1/images/edits.

  - name: cloudflare:dreamshaper
    kind: cloudflare_image
    model: "@cf/lykon/dreamshaper-8-lcm"
    api_key_env: CLOUDFLARE_API_KEY
    timeout: 90
    latency_s: 1.5
    quality: 60

  - name: cloudflare:sdxl-lightning
    kind: cloudflare_image
    model: "@cf/bytedance/stable-diffusion-xl-lightning"
    api_key_env: CLOUDFLARE_API_KEY
    timeout: 90
    latency_s: 2.0
    quality: 62

  - name: cloudflare:phoenix
    kind: cloudflare_image
    model: "@cf/leonardo/phoenix-1.0"
    api_key_env: CLOUDFLARE_API_KEY
    timeout: 90
    latency_s: 3.0
    quality: 65

  # === AI Horde (бывший Stable Horde) — community-distributed inference ===
  # Полностью бесплатно, БЕЗ РЕГИСТРАЦИИ. apikey="0000000000" — anonymous,
  # low priority в общей очереди. Async (job + poll), median wait ~30s-2min.
  # Совершенно отдельный пул квот от CF/Pollinations — спасает когда те 429.
  # Models: список через https://aihorde.net/api/v2/status/models
  - name: aihorde:flux-schnell
    kind: aihorde
    model: "Flux.1-Schnell fp8 (Compact)"
    steps: 8         # schnell native
    sampler_name: k_euler
    cfg_scale: 1.0   # FLUX schnell — distilled, cfg=1
    max_wait_s: 300
    timeout: 360
    latency_s: 60.0  # включает очередь — может быть и 5s, и 3min
    quality: 70

  - name: aihorde:sdxl
    kind: aihorde
    model: "AlbedoBase XL (SDXL)"
    steps: 20
    sampler_name: k_euler
    cfg_scale: 7.0
    max_wait_s: 300
    timeout: 360
    latency_s: 60.0
    quality: 65

  - name: aihorde:dreamshaper
    kind: aihorde
    model: "Dreamshaper"
    steps: 20
    sampler_name: k_euler
    cfg_scale: 7.0
    max_wait_s: 300
    timeout: 360
    latency_s: 60.0
    quality: 60

  # === Together AI — FLUX.1-schnell-Free ===
  # OpenAI-совместимый /v1/images/generations.
  # Статус 2026-04-22: эндпоинт принимает ключ, но возвращает HTTP 402
  # "Credit limit exceeded" — signup-кредиты исчерпаны, даже free-suffix
  # модель требует положительного баланса. Провайдер оставлен для случая,
  # когда на аккаунте появятся кредиты; не включён в image_gen chain.
  - name: together:flux-1-schnell-free
    kind: together_image
    model: black-forest-labs/FLUX.1-schnell-Free
    api_key_env: TOGETHER_API_KEY
    steps: 4
    timeout: 90
    latency_s: 2.5
    quality: 68

  # === Translation (text→text, только для цепочки `translation`) ===
  # Специализированные MT-провайдеры. Sync, возвращают TranslationResult с
  # {text, source_lang, target_lang}. Не участвуют в chat-цепочках — chat()
  # бросает NotImplementedError.
  #
  # Состояние бесплатных MT API на 2026-04-23 (live-probe):
  #   libretranslate.com/.de — стали paid-only (HTTP 400 «visit portal.libretranslate.com»)
  #   translate.argosopentech.com / terraprint / vern-mirror — мертвы (DNS/502)
  #   translate.fedilab.app — жив (200 OK) ← LibreTranslate-compat
  #   api.mymemory.translated.net — жив, 5000 chars/day anon, 50000 с ?de=email
  # DeepL/Microsoft/Yandex/Cohere Aya — требуют ключей (не заданы в env),
  # добавить как kinds когда будут ключи (deepl/ms_translator/yandex_translate/cohere).

  - name: yandex:translate
    kind: yandex_translate
    api_key_env: YANDEX_TRANSLATE_KEY
    # folder_id берётся из YANDEX_FOLDER_ID автоматически. Можно переопределить
    # полем `folder_id:` в конфиге если нужен другой каталог.
    timeout: 30
    rpd: 33000   # 1M chars/мес grant / 30 дней ≈ 33K символов/день, мягкий soft-cap в requests
    rpm: 60
    latency_s: 0.5   # измерено 2026-04-24 на ru→en (Рэлей)
    ru: 90   # scan-00/06 ★★★★★ RU, Yandex-флагман для русского
    quality: 40   # собственный MT-движок, не LLM (сравним с Qwen-397B по качеству на RU)

  # --- Cohere chat (trial tier) — kind: cohere_chat (отдельно от cohere=translate) ---
  # Trial: 20 RPM, 1000 calls/мес. Документация не уточняет shared/per-model для месячного
  # квотума; rpd=33 на каждой как safe-floor (1000/30). Если квотум окажется per-model,
  # суммарно получим 4×33≈132 RPD по Cohere; если shared — все Cohere делят один пул.

  - name: cohere:command-r
    kind: cohere_chat
    model: command-r-08-2024
    api_key_env: COHERE_API_KEY
    rpm: 20
    rpd: 33
    timeout: 60
    quality: 18      # estimate 2026-05-02 (smoke 2026-05-02; trial 1K calls/мес)
    latency_s: 1.1
    ru: 80           # estimate 2026-05-02

  - name: cohere:command-r-plus
    kind: cohere_chat
    model: command-r-plus-08-2024
    api_key_env: COHERE_API_KEY
    rpm: 20
    rpd: 33
    timeout: 120
    quality: 22      # estimate 2026-05-02 (smoke 2026-05-02; 104B)
    latency_s: 1.2
    ru: 82           # estimate 2026-05-02

  - name: cohere:command-r7b
    kind: cohere_chat
    model: command-r7b-12-2024
    api_key_env: COHERE_API_KEY
    rpm: 20
    rpd: 33
    timeout: 60
    quality: 10      # estimate 2026-05-02 (smoke 2026-05-02; tiny 7B)
    latency_s: 1.0
    ru: 70           # estimate 2026-05-02

  # Command A — флагман Cohere (111B, 256K context). Trial: 20 RPM, 1000 calls/мес.
  # awesome-free-llm-apis 2026-05.
  - name: cohere:command-a
    kind: cohere_chat
    model: command-a-03-2025
    api_key_env: COHERE_API_KEY
    rpm: 20
    rpd: 33
    timeout: 120
    quality: 0       # estimate — топ-модель Cohere
    latency_s: 0     # estimate
    ru: 0            # estimate

  - name: cohere:aya-expanse-32b
    kind: cohere
    model: c4ai-aya-expanse-32b
    api_key_env: COHERE_API_KEY
    # Trial tier 2026-04: 1000 calls/мес, 20 RPM per-model. rpd=33 — мягкий
    # дневной floor чтобы не выжечь месячный квотум за день (1000/30≈33).
    rpm: 20
    rpd: 33
    timeout: 60
    latency_s: 1.1   # измерено 2026-04-23 на ru→en на Рэлее
    ru: 82   # Aya Expanse 32B — multilingual-first, 102 lang, scan-00 ★★★★ RU (=82 в нашей шкале)
    quality: 35   # консервативная оценка на уровне MiniMax M2.5 / Nemotron-3-Super

  - name: libretranslate:fedilab
    kind: libretranslate
    base_url: https://translate.fedilab.app
    # Community-mirror, без API-ключа. Может падать/медленеть — поэтому первый fallback.
    timeout: 20
    latency_s: 0.5   # измерено 2026-04-23 на "Привет, мир" ru→en
    ru: 70   # LibreTranslate использует Argos Translate (OpenNMT), грамматика ок, но контекст слабее DeepL

  - name: mymemory:free
    kind: mymemory
    # contact_email берётся из env MYMEMORY_CONTACT_EMAIL — с email лимит 50000 chars/day (без — 5000).
    timeout: 15
    # rpd — soft-cap в ЗАПРОСАХ (не chars). 800×~60 chars ≈ 48K/сутки если email задан;
    # без email опускай до ~80. На жёсткий 429 включается cooldown в RateTracker (см. router._handle_failure).
    rpd: 800
    latency_s: 0.4   # измерено 2026-04-23 на "Привет" ru→en (~400ms round-trip)
    ru: 74   # TM-база (гибрид MT + translation memory) — приличная для популярных пар; не поддерживает source=auto

  # ==================================================================================
  # Дополнительные free-провайдеры (добавлены 2026-05-13 по awesome-free-llm-apis)
  # Не подмешаны в основные chains автоматически — добавь вручную туда, где нужно.
  # Метрики quality/latency/ru = 0 (estimate) — прогнать бенчи перед включением в chain.
  # ==================================================================================

  # --- OVHcloud AI Endpoints (anonymous, EU) — 2 RPM per-IP per-model, БЕЗ ключа ---
  # endpoints.ai.cloud.ovh.net. Free anonymous tier работает без регистрации.
  # Подойдёт как deep fallback / для EU-юзеров. С API-ключом — 400 RPM per Public
  # Cloud project, PAYG-биллинг + до $200 trial-кредитов на новый аккаунт.

  - name: ovhcloud:llama-3.3-70b
    kind: ovhcloud
    model: Meta-Llama-3_3-70B-Instruct
    # api_key_env не задан → anonymous, провайдер пропускает Authorization header
    rpm: 2  # anonymous per-IP
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0

  - name: ovhcloud:qwen3-32b
    kind: ovhcloud
    model: Qwen3-32B
    rpm: 2
    timeout: 180
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  - name: ovhcloud:deepseek-r1-distill-70b
    kind: ovhcloud
    model: DeepSeek-R1-Distill-Llama-70B
    rpm: 2
    timeout: 180
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  - name: ovhcloud:qwen2.5-vl-72b
    kind: ovhcloud
    model: Qwen2.5-VL-72B-Instruct
    rpm: 2
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0
    vision: true

  - name: ovhcloud:qwen3-coder-30b
    kind: ovhcloud
    model: Qwen3-Coder-30B-A3B-Instruct
    rpm: 2
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0

  # --- HuggingFace Inference Providers Router (router.huggingface.co/v1) ---
  # Free token = ~$0.10/мес кредитов на shared pool (paid sub-providers).
  # Модель = "<repo>:<provider>" — Novita / Together / Fireworks / SambaNova и т.д.
  # Здесь — текстовые LLM (audio через kind: hf_space_audio уже есть выше).

  # ⚠️ Router-id != HF repo id: префикс "Meta-" в Llama-3.1 убран. См. полный список
  # доступных моделей: GET https://router.huggingface.co/v1/models с Bearer HF_TOKEN.
  - name: huggingface:llama-3.1-8b
    kind: huggingface
    model: meta-llama/Llama-3.1-8B-Instruct
    api_key_env: HF_TOKEN
    rpd: 1000      # ~$0.10/мес shared free credits — soft floor
    timeout: 60
    quota_limited: true   # общий $0.10/мес pool
    # smoke 2026-05-13: HTTP 200, RU OK (ответ "Да."), 44 total_tokens на простой prompt.
    quality: 0
    latency_s: 0
    ru: 0

  - name: huggingface:llama-3.3-70b
    kind: huggingface
    model: meta-llama/Llama-3.3-70B-Instruct
    api_key_env: HF_TOKEN
    rpd: 1000
    timeout: 120
    quota_limited: true
    quality: 0
    latency_s: 0
    ru: 0

  - name: huggingface:qwen2.5-7b
    kind: huggingface
    model: Qwen/Qwen2.5-7B-Instruct
    api_key_env: HF_TOKEN
    rpd: 1000
    timeout: 60
    quota_limited: true
    quality: 0
    latency_s: 0
    ru: 0

  - name: huggingface:deepseek-r1-distill-llama-8b
    kind: huggingface
    model: deepseek-ai/DeepSeek-R1-Distill-Llama-8B
    api_key_env: HF_TOKEN
    rpd: 1000
    timeout: 120
    quota_limited: true
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  # --- SiliconFlow (cloud.siliconflow.cn) — 1000 RPM / 50K TPM на free ---
  # 14 CNY signup credits, permanent-free модели. Самые щедрые лимиты в списке.
  # ⚠️ CN-провайдер: латентность из EU/RU может прыгать, real-name verification.

  - name: siliconflow:qwen3-8b
    kind: siliconflow
    model: Qwen/Qwen3-8B
    api_key_env: SILICONFLOW_API_KEY
    rpm: 1000
    timeout: 120
    # smoke 2026-05-13: HTTP 200, RU OK, по дефолту thinking on → 364 reasoning_tokens на простом prompt.
    # Чтобы экономить бюджет 50K TPM — добавь `extra_body: {enable_thinking: false}` если не нужен reasoning.
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  - name: siliconflow:glm-4.1v-9b-thinking
    kind: siliconflow
    model: THUDM/GLM-4.1V-9B-Thinking
    api_key_env: SILICONFLOW_API_KEY
    rpm: 1000
    timeout: 180
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true
    vision: true

  - name: siliconflow:deepseek-r1-distill-7b
    kind: siliconflow
    model: deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
    api_key_env: SILICONFLOW_API_KEY
    rpm: 1000
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  - name: siliconflow:deepseek-r1-0528-qwen3-8b
    kind: siliconflow
    model: deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
    api_key_env: SILICONFLOW_API_KEY
    rpm: 1000
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  # DeepSeek-OCR — уникальная free OCR-модель (image → text).
  - name: siliconflow:deepseek-ocr
    kind: siliconflow
    model: deepseek-ai/DeepSeek-OCR
    api_key_env: SILICONFLOW_API_KEY
    rpm: 1000
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0
    vision: true

  # --- LLM7.io (UK, OpenAI-compat gateway) ---
  # ⚠️ smoke 2026-05-13: awesome-free-llm-apis README врёт — gpt-4o-mini/gemini/
  # deepseek/qwen НЕ работают, model field в request silently игнорируется. /v1/models
  # отдаёт 5 идов, но реально живой ОДИН: codestral-latest. Остальное (gpt-oss-20b,
  # GLM-4.6V-Flash) тоже роутится на codestral; llama-3.1-8b-turbo и ministral-8b
  # возвращают пустой content.
  # НО: 120 RPM с токеном (30 anonymous) на codestral — это 30× выше чем прямой
  # mistral:codestral на Experiment plan (rpm:4). Отличный overflow для кодинга.

  - name: llm7:codestral
    kind: llm7
    model: codestral-latest
    api_key_env: LLM7_API_KEY   # пустой → anonymous 30 RPM режим
    rpm: 120   # с токеном; без токена — снизь до 30
    timeout: 60
    # quality/latency/ru = 0 → прогнать бенчи. Mistral Codestral сильна в коде, RU средний.
    quality: 0
    latency_s: 0
    ru: 0

  # --- ModelScope API-Inference (modelscope.cn) — 2000 RPD shared ---
  # ⚠️ Требует Alibaba Cloud International + real-name verification (паспорт).
  # ≤500 RPD на модель, динамические per-model квоты + concurrency.

  - name: modelscope:qwen3.5-35b
    kind: modelscope
    model: Qwen/Qwen3.5-35B-A3B
    api_key_env: MODELSCOPE_API_KEY
    rpd: 500   # per-model cap
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0
    vision: true

  - name: modelscope:qwen3.5-27b
    kind: modelscope
    model: Qwen/Qwen3.5-27B
    api_key_env: MODELSCOPE_API_KEY
    rpd: 500
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0

  # --- Kilo Code (kilo.ai) ~200 req/hr на ключ ---
  # ⚠️ smoke 2026-05-13: из README кодекса awesome-free-llm-apis уже отвалились
  # minimax-m2.5:free, bytedance dola-seed:free, trinity-large-thinking:free —
  # все возвращают "free period ended". x-ai/grok-code-fast-1 требует /responses
  # endpoint (не OpenAI chat-compat). Живые: kilo-auto/free → routing на stepfun
  # step-3.5-flash:free + nvidia/nemotron-3-super-120b-a12b:free.
  # ⚠️ nemotron-3-super:free — trial mode, NVIDIA логирует промпты.
  # Все живые модели — thinking-модели, ответ в reasoning, не в content!

  - name: kilo:auto-free
    kind: kilo
    model: kilo-auto/free
    api_key_env: KILO_API_KEY
    rpm: 3   # ~200/hr ≈ 3.3/min
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true   # routes на step-3.5-flash (thinking)

  - name: kilo:step-3.5-flash
    kind: kilo
    model: stepfun/step-3.5-flash:free
    api_key_env: KILO_API_KEY
    rpm: 3
    timeout: 120
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  - name: kilo:nemotron-3-super
    kind: kilo
    model: nvidia/nemotron-3-super-120b-a12b:free
    api_key_env: KILO_API_KEY
    rpm: 3
    timeout: 180
    quota_limited: true   # ⚠️ trial-only: NVIDIA логирует промпты — не используй для приватных данных
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  # --- Ollama Cloud (ollama.com) — OpenAI-compat /v1, free-tier ---
  # Smoke 2026-05-13: из 13 моделей awesome-free-llm-apis только 5 доступны free,
  # остальные 8 требуют Pro ($20/мес 50×) или Max ($50 250×) — закомменчены ниже.
  # Полный список доступных моделей: GET https://ollama.com/api/tags (без auth).
  # Free tier — "light usage" (session/weekly GPU-time cap, без публичных цифр).

  - name: ollama:qwen3-coder-480b
    kind: ollama
    model: "qwen3-coder:480b"
    api_key_env: OLLAMA_API_KEY
    quota_limited: true
    timeout: 240
    quality: 0
    latency_s: 0
    ru: 0

  - name: ollama:qwen3-vl-235b
    kind: ollama
    model: "qwen3-vl:235b"
    api_key_env: OLLAMA_API_KEY
    quota_limited: true
    timeout: 180
    quality: 0
    latency_s: 0
    ru: 0
    vision: true
    reasoning: true   # thinking on by default

  - name: ollama:glm-4.7
    kind: ollama
    model: glm-4.7
    api_key_env: OLLAMA_API_KEY
    quota_limited: true
    timeout: 180
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true   # thinking on by default

  - name: ollama:devstral-123b
    kind: ollama
    model: "devstral-2:123b"
    api_key_env: OLLAMA_API_KEY
    quota_limited: true
    timeout: 240
    quality: 0
    latency_s: 0
    ru: 0

  - name: ollama:minimax-m2.5
    kind: ollama
    model: minimax-m2.5
    api_key_env: OLLAMA_API_KEY
    quota_limited: true
    timeout: 180
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true   # thinking on by default

  # ⚠️ Pro/Max-only — раскомментируй после ollama.com/upgrade:
  # - name: ollama:deepseek-v4-pro    # требует Pro
  # - name: ollama:deepseek-v4-flash  # требует Pro
  # - name: ollama:kimi-k2-thinking   # требует Pro
  # - name: ollama:kimi-k2.5          # требует Pro
  # - name: ollama:kimi-k2-1t         # требует Pro (kimi-k2:1t, 1 триллион params)
  # - name: ollama:qwen3.5-397b       # требует Pro
  # - name: ollama:mistral-large-3    # требует Pro (mistral-large-3:675b)
  # - name: ollama:glm-5.1            # требует Pro

  # === Paid-only ===
  # ВАЖНО: используется OPENROUTER_PAID_API_KEY (с $4 credit), НЕ основной OR-ключ
  # который имеет limit=0 — на нём paid-запросы всегда падают credit_exceeded.
  # не использовать ключ нигде самостоятельно

  - name: openrouter:claude-opus-4.7
    kind: openrouter
    model: anthropic/claude-opus-4.7
    api_key_env: OPENROUTER_PAID_API_KEY
    quality: 58   # AA Index v4.0 оценка (Opus 4.7 extended thinking; подтвердить)
    # latency_s: бенч не прогонялся для paid
    ru: 85   # Claude Opus — эталон RU (без прогона, по внешним наблюдениям)

  # OpenAI gpt-5-mini — paid-fallback после Opus. $0.25/1M in, $2.00/1M out.
  # Использует отдельный $5-аккаунт (OPENAI_API_KEY_PAID), чтобы не путать с
  # бесплатной модерацией на основном OPENAI_API_KEY. Если ключ пуст — выпадает
  # из chain автоматически.
  - name: openai:gpt-5-mini
    kind: openai
    model: gpt-5-mini
    api_key_env: OPENAI_API_KEY_PAID
    quality: 40   # AA Index v4.0 (примерно; уточнить после прогонов)
    # latency_s: бенч не прогонялся для paid
    ru: 90   # multilingual SOTA в линейке gpt-5

  # === GigaChat (SberDevices) ===
  # PERS scope: бесплатный personal-tier (1M токенов на 30 дней при регистрации).
  # Авторизация двухступенчатая: Basic Authorization key → access_token (TTL 30 мин) → Bearer.
  # Сертификат cubehost подписан Russian Trusted Root CA, поэтому verify_ssl: false по умолчанию.
  # api_key_env: GIGACHAT_AUTH_KEY — base64("<client_id>:<client_secret>") из консоли developers.sber.ru.

  - name: gigachat:2
    kind: gigachat
    model: GigaChat-2
    api_key_env: GIGACHAT_AUTH_KEY
    scope: GIGACHAT_API_PERS
    verify_ssl: false
    quality: 30        # ориентировочно (RU-native LLM, AA-неоценено; mid-tier по чувству)
    latency_s: 1.6     # измерено 2026-04-25, max_tokens=300, RU prompt
    ru: 60        # bench: 12/20 (auto, 1.21s avg)

  - name: gigachat:2-pro
    kind: gigachat
    model: GigaChat-2-Pro
    api_key_env: GIGACHAT_AUTH_KEY
    scope: GIGACHAT_API_PERS
    verify_ssl: false
    quality: 35        # ориентировочно (RU-native pro-tier)
    latency_s: 1.9
    ru: 70        # bench: 14/20 (auto, 1.59s avg)

  - name: gigachat:2-max
    kind: gigachat
    model: GigaChat-2-Max
    api_key_env: GIGACHAT_AUTH_KEY
    scope: GIGACHAT_API_PERS
    verify_ssl: false
    quality: 40        # ориентировочно (RU-native top-tier; сопоставим с Qwen 397B на RU-задачах)
    latency_s: 2.4
    ru: 70        # bench: 14/20 (auto, 1.76s avg)

  # === Yandex AI Studio (Foundation Models) ===
  # OpenAI-compat /v1/chat/completions, auth: Authorization: Api-Key <key>.
  # Биллится из Yandex AI Studio баланса (новым аккаунтам обычно дают grant).
  # quota_limited: true — провайдер потребляет грант/деньги, в дашборде помечен 💳.
  # api_key_env переиспользует YANDEX_TRANSLATE_KEY (тот же сервисный аккаунт),
  # folder_id берётся из YANDEX_FOLDER_ID env.

  # Alice AI LLM (Yandex, окт 2025) — флагман над YandexGPT-Pro по диалогу и длинному
  # контексту, лидер RU-бенчмарка SLAVA. Цена ~0.50/1.20 ₽ за 1K input/output —
  # дороже Pro в 2-3×, но если есть Yandex grant — покрывается.
  - name: yandex:alice
    kind: yandex_foundation
    model: aliceai-llm/latest
    api_key_env: YANDEX_TRANSLATE_KEY
    quota_limited: true
    quality: 35        # ориентировочно (заявлен >YandexGPT Pro)
    latency_s: 0.8     # bench 2026-04-25, 20-prompt avg
    ru: 90             # bench: 18/20 (упустила instr_7_words и instr_no_o — общий хвост)

  - name: yandex:art
    kind: yandex_art
    model: yandex-art/latest
    api_key_env: YANDEX_TRANSLATE_KEY
    quota_limited: true
    quality: 70        # YandexART качество ~ FLUX.1-dev (оценка)
    latency_s: 6.0     # async + poll, ~6с на 1024×1024

  - name: gigachat:kandinsky
    kind: gigachat_image
    model: GigaChat-2-Max
    api_key_env: GIGACHAT_AUTH_KEY
    scope: GIGACHAT_API_PERS
    verify_ssl: false
    quota_limited: true
    quality: 65        # Kandinsky 3.1 (оценка; RU-friendly, 1024×1024 only)
    latency_s: 8.0     # генерация + fetch файла, заметно медленнее YandexART

  # === Embeddings — text + code, через /v1/embeddings ===
  # Все модели верифицированы live-probe 2026-04-25 (см. apicount.md).
  # `dim` = нативная размерность (для Voyage/Jina-v5 поддерживается MRL truncation
  # через payload `dimensions=N` в запросе пользователя).

  # --- text-embeddings ---
  - name: voyage:voyage-3.5
    kind: voyage_embed
    model: voyage-3.5
    api_key_env: VOYAGE_API_KEY
    dim: 1024
    quality: 80        # Voyage-3.5 — MTEB-multi top tier (оценка)
    # 200M tok permanent free per-model — независимый бакет от chat-провайдеров.
    # Без RPM-кэпа в free-tier (на 2026-04-25); ограничение только по token-pool.

  - name: voyage:voyage-3.5-lite
    kind: voyage_embed
    model: voyage-3.5-lite
    api_key_env: VOYAGE_API_KEY
    dim: 1024
    quality: 70        # быстрее/дешевле, точность ниже на ~3pp

  - name: voyage:voyage-3-large
    kind: voyage_embed
    model: voyage-3-large
    api_key_env: VOYAGE_API_KEY
    dim: 1024
    quality: 78        # large-checkpoint, выше ванильного 3.5 на сложных запросах

  - name: jina:embeddings-v5-text-small
    kind: jina_embed
    model: jina-embeddings-v5-text-small
    api_key_env: JINA_API_KEY
    dim: 1024
    extra_body:
      task: retrieval.passage   # default — индексация. Override: `task: retrieval.query` в запросе.
      normalized: true
    quality: 75        # Jina v5 small — лучший free multi-lingual (89 langs)

  - name: jina:embeddings-v3
    kind: jina_embed
    model: jina-embeddings-v3
    api_key_env: JINA_API_KEY
    dim: 1024
    extra_body:
      task: retrieval.passage
    quality: 70        # v3 — стабильный fallback если v5 затупит

  - name: gemini:embedding-001
    kind: gemini_embed
    model: gemini-embedding-001
    api_key_env: GEMINI_API_KEY
    dim: 3072
    rpd: 1500          # delит pool с chat-Gemini того же ключа — на индексации легко выжечь chat
    rpm: 100
    quality: 78        # MTEB-multi сильный, но shared quota — поэтому не первым

  - name: cohere:embed-multilingual-v3
    kind: cohere_embed
    model: embed-multilingual-v3.0
    api_key_env: COHERE_API_KEY
    dim: 1024
    quota_limited: true  # 1000 calls/мес trial — экономим
    quality: 73

  - name: cohere:embed-v4
    kind: cohere_embed
    model: embed-v4.0
    api_key_env: COHERE_API_KEY
    dim: 1536
    quota_limited: true  # тот же 1000/мес pool
    quality: 80        # SOTA в multilingual + image (но image не используем тут)

  - name: mistral:embed
    kind: mistral_embed
    model: mistral-embed
    api_key_env: MISTRAL_API_KEY
    dim: 1024
    rpm: 4             # тот же 4 RPM Experiment plan что у chat-Mistral (shared)
    quality: 65

  - name: github:text-embedding-3-large
    kind: github_embed
    model: openai/text-embedding-3-large
    api_key_env: GITHUB_MODELS_TOKEN
    dim: 3072
    rpm: 10
    rpd: 50            # Copilot-free per-model bucket
    quality: 72

  - name: github:text-embedding-3-small
    kind: github_embed
    model: openai/text-embedding-3-small
    api_key_env: GITHUB_MODELS_TOKEN
    dim: 1536
    rpm: 15
    rpd: 150
    quality: 60

  - name: nvidia:nv-embedqa-e5-v5
    kind: nvidia_embed
    model: nvidia/nv-embedqa-e5-v5
    api_key_env: NVIDIA_API_KEY
    dim: 1024
    rpm: 40
    extra_body:
      input_type: query   # NV-EmbedQA требует input_type. По умолчанию query;
                           # для индексации передавай `input_type: passage` в запросе.
    quality: 60        # 512 ctx — узкое горлышко для длинных чанков

  - name: cloudflare:bge-m3
    kind: cloudflare_embed
    model: "@cf/baai/bge-m3"
    api_key_env: CLOUDFLARE_API_KEY
    dim: 1024
    rpd: 300           # часть 10K neurons/день shared pool
    quality: 55        # bge-m3 ниже среднего на новых бенчах

  # --- code-embeddings ---
  - name: voyage:voyage-code-3
    kind: voyage_embed
    model: voyage-code-3
    api_key_env: VOYAGE_API_KEY
    dim: 1024
    quality: 85        # SOTA для code-search (MTEB-Code, 2025)

  - name: jina:code-embeddings-1.5b
    kind: jina_embed
    model: jina-code-embeddings-1.5b
    api_key_env: JINA_API_KEY
    dim: 1536
    extra_body:
      task: retrieval.passage
      normalized: true
    quality: 78        # новейший Jina code-embedder (2026)

  - name: mistral:codestral-embed
    kind: mistral_embed
    model: codestral-embed
    api_key_env: MISTRAL_API_KEY
    dim: 1536
    rpm: 4             # shared с chat-Mistral pool
    quality: 75

  - name: jina:embeddings-v2-base-code
    kind: jina_embed
    model: jina-embeddings-v2-base-code
    api_key_env: JINA_API_KEY
    dim: 768
    quality: 60        # старый, но проверенный last-resort

  # === Reranker — POST /rerank, второй этап RAG (cross-encoder поверх top-N) ===
  # Все три провайдера принимают {query, documents:[str], top_n}, возвращают
  # отсортированный список {index, relevance_score}. Шейпы почти идентичны —
  # унифицированы в RerankProvider (Voyage использует top_k/data вместо top_n/results).

  - name: jina:reranker-v3
    kind: jina_rerank
    model: jina-reranker-v3
    api_key_env: JINA_API_KEY
    quality: 88        # SOTA multilingual reranker (2026), 131K total ctx
    ru: 90
    # 10M tok pool на ключ — общий с Jina embeddings/Reader.

  - name: jina:reranker-v2-base-multilingual
    kind: jina_rerank
    model: jina-reranker-v2-base-multilingual
    api_key_env: JINA_API_KEY
    quality: 78        # стабильный fallback v2 (8K ctx)
    ru: 85

  - name: cohere:rerank-v3.5
    kind: cohere_rerank
    model: rerank-v3.5
    api_key_env: COHERE_API_KEY
    quota_limited: true  # 1000 calls/мес trial — общий с cohere-embed
    quality: 85        # SOTA EN/multilingual, 4K ctx
    ru: 90

  - name: voyage:rerank-2.5
    kind: voyage_rerank
    model: rerank-2.5
    api_key_env: VOYAGE_API_KEY
    quality: 80        # 32K ctx — длинные документы переживёт лучше Cohere/Jina-v2
    ru: 75
    # 200M tok permanent free per-model — независимый от chat бакет.

  - name: voyage:rerank-2.5-lite
    kind: voyage_rerank
    model: rerank-2.5-lite
    api_key_env: VOYAGE_API_KEY
    quality: 70        # быстрее/дешевле, last-resort

  # === Moderation (text + image, только для цепочек `moderation*`) ===
  # Шейп ответа единый — OpenAI omni-moderation:
  #   {results: [{flagged, categories, category_scores}]}
  # Llama Guard выдаёт `safe`/`unsafe\nS1,S5` — парсер мапит S-коды в OpenAI-категории.
  # Llama Guard 4 12B мультимодальный (multimodal: true), Guard 3-8B и Prompt Guard — text-only.

  - name: openai:moderation
    kind: openai_moderation
    model: omni-moderation-latest
    api_key_env: OPENAI_API_KEY
    timeout: 30
    quality: 90    # эталон, 13 категорий, native scores
    latency_s: 0.4
    ru: 85         # SOTA на multilingual

  # Legacy text-only OpenAI moderation (7 категорий, без image, без category_scores).
  # Тот же бесплатный endpoint /v1/moderations, тот же ключ. Держим как backup
  # к omni-moderation: если omni упадёт по сети, text-moderation чаще живёт
  # (старая дешёвая модель, отдельный pool).
  - name: openai:text-moderation
    kind: openai_moderation
    model: text-moderation-latest
    api_key_env: OPENAI_API_KEY
    timeout: 30
    quality: 65    # legacy, 7 категорий, без scores на части полей
    latency_s: 0.3
    ru: 70         # multilingual, но слабее чем omni

  - name: mistral:moderation
    kind: mistral_moderation
    model: mistral-moderation-latest
    api_key_env: MISTRAL_API_KEY
    timeout: 30
    quality: 70    # text-only, 9 категорий с scores
    latency_s: 0.5
    ru: 80
    rpm: 4   # та же Experiment-квота что и chat-mistral (per-key минута)

  # Cloudflare Workers AI — единственный бесплатный Llama-Guard-style endpoint
  # с реально живыми лимитами (10K neurons/день). 3-8B text-only.
  - name: cloudflare:llama-guard-3-8b
    kind: llama_guard
    host: cloudflare
    model: "@cf/meta/llama-guard-3-8b"
    api_key_env: CLOUDFLARE_API_KEY
    multimodal: false
    rpd: 300
    quality: 50
    latency_s: 0.8
    ru: 60

  # Groq Llama-Prompt-Guard-2 — узкий специалист по prompt-injection / jailbreak
  # детекции (НЕ general moderation). Держим в moderation_jailbreak first.
  # Llama-Guard-4-12B на Groq decommissioned 2026-04 — заменён prompt-guard-2.
  - name: groq:prompt-guard-2-86m
    kind: llama_guard
    host: groq
    model: meta-llama/llama-prompt-guard-2-86m
    api_key_env: GROQ_API_KEY
    multimodal: false
    rpm: 30
    rpd: 1000
    quality: 55
    latency_s: 0.4
    ru: 30   # EN-trained

  # Together AI Llama Guard 4 12B — multimodal (text+image). Free тиер user'а
  # на 2026-04-25 = 0 credits (HTTP 402). Оставляем определение чтобы при
  # добавлении кредитов можно было раскомментировать в chains. quota_limited:true
  # → router пропускает быстрее на rate_capped/non-retryable ошибках.
  - name: together:llama-guard-4
    kind: llama_guard
    host: together
    model: meta-llama/Llama-Guard-4-12B
    api_key_env: TOGETHER_API_KEY
    multimodal: true
    quota_limited: true
    timeout: 60
    quality: 65
    latency_s: 0.7
    ru: 75

  - name: together:qwen3-guard
    kind: llama_guard
    host: together
    model: Qwen/Qwen3-Guard-Stream-8B
    api_key_env: TOGETHER_API_KEY
    multimodal: false
    quota_limited: true
    timeout: 60
    quality: 60
    latency_s: 0.9
    ru: 85   # Qwen — лучший open-weight safety classifier для не-EN языков

  # === FreeTheAi (api.freetheai.xyz) — OpenAI-compat, ~16k aliases ===================
  # ⚠️ Все эти провайдеры требуют DAILY Discord /checkin (https://discord.gg/secrets,
  # канал #api-keys, команда /checkin). Без чек-ина любой запрос → HTTP 403
  # daily_checkin_required. Автоматизировать НЕЛЬЗЯ (Discord ToS). Из-за этого
  # стоят в самом ХВОСТЕ chat-цепочки и отдельными позициями в quality:
  # активны только когда чек-ин свежий, иначе быстро отваливаются и пропускаются.
  # Лимит 10 RPM + 1 concurrent делится на ВСЕХ freetheai-моделей вместе (один ключ).
  # Метрики latency_s измерены 2026-05-08 через probe v1-v4. RU-проверка пройдена для
  # bbg/* (правильно ответили "Москва"). cat/* — identity-check на уровне claims, не
  # верифицирован глубже. cat/claude-* и bbg/deepseek-v4-pro — bait, не подключены.
  - name: freetheai:gemini-2.5-flash
    kind: freetheai
    model: bbl/gemini-2.5-flash
    api_key_env: FREETHEAI_API_KEY
    rpm: 10  # shared bucket на все freetheai-провайдеры
    timeout: 60
    latency_s: 4.1
    # ru: не верифицирован отдельным RU-бенчем

  - name: freetheai:gpt-5
    kind: freetheai
    model: cat/gpt-5
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 60
    latency_s: 5.3
    # identity claim: "embedded in FreeTheAi.xyz, built by OpenAI"

  - name: freetheai:gpt-5-mini
    kind: freetheai
    model: cat/gpt-5-mini
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 60
    latency_s: 5.6
    # identity claim: "I am ChatGPT, a large language model created by OpenAI"

  - name: freetheai:minimax-m2.7
    kind: freetheai
    model: bbg/MiniMaxAI/MiniMax-M2.7
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 90  # reasoning, дольше
    latency_s: 5.2
    reasoning: true
    ru: 75   # probe v2: правильно ответил "Москва"

  - name: freetheai:kimi-k2.6
    kind: freetheai
    model: bbg/moonshotai/Kimi-K2.6
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 90
    latency_s: 7.2
    reasoning: true
    ru: 75   # probe v2: " Москва"

  - name: freetheai:glm-5.1
    kind: freetheai
    model: bbg/zai-org/GLM-5.1
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 90
    latency_s: 8.7
    reasoning: true
    ru: 80   # probe v2: правильно "Москва", #3 в leaderboard

  # === FreeTheAi image-gen — kind: freetheai_image. URL-ответы vhr/* протухают
  # за ~30 мин (404), поэтому FreeTheAiImageProvider скачивает + перекодирует в
  # b64 во время запроса. Делит ту же 10 RPM / 1 concurrent квоту, что и chat-
  # провайдеры (один ключ). Все хвостом в image_gen после CF/Yandex/GigaChat.
  - name: freetheai_image:seedream_v4
    kind: freetheai_image
    model: vhr/bytedance_seedream_v4
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 60
    latency_s: 15.5  # gen-only, без download (download +1-3s сверху)
    quality: 70      # 768×768+, фотореализм OK на тестах с яблоком

  - name: freetheai_image:flux_dev
    kind: freetheai_image
    model: vhr/flux_dev
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 60
    latency_s: 17.0
    quality: 65

  - name: freetheai_image:nano_banana_2
    kind: freetheai_image
    model: vhr/nano_banana_2
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 60
    latency_s: 22.7
    quality: 60

  - name: freetheai_image:gpt_image_2
    kind: freetheai_image
    model: img/gpt-image-2
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 90
    latency_s: 21.0  # b64 native (~650KB PNG), без extra download
    quality: 70
    # ⚠️ upstream — реальный OpenAI gpt-image на общем пуле. 429 случается часто.

  - name: freetheai_image:gpt_image_2_vhr
    kind: freetheai_image
    model: vhr/gpt_image_2
    api_key_env: FREETHEAI_API_KEY
    rpm: 10
    timeout: 90
    latency_s: 30.5
    quality: 65

# ==================================================================================
# Цепочки. Порядок = приоритет фоллбэка.
# ==================================================================================

default_chain: chat

chains:
  # --- chat: RU-floor + AA tiebreak (deepchain1) ---
  # deepseek:v4-flash убран из чейнов 2026-05-12 — аккаунт 0 баланса, 402 ломал
  # chain (router считает 402 non-retryable). Провайдер остался в `providers:` —
  # доступен через прямой `model=deepseek:v4-flash` после пополнения.
  chat:
    - github:gpt-4.1-mini
    - yandex:alice
    - gemini:2.5-flash-lite
    - sambanova:llama-4-maverick
    - freetheai:gemini-2.5-flash         # 4.1s · переехал из хвоста (circuit-breaker, 2026-05-08)
    - openrouter:minimax-m2.5-free
    - cerebras:qwen-3-235b
    - gemini:flash-lite-latest
    - gemini:2.5-flash
    - sambanova:deepseek-v3.2
    - freetheai:gpt-5                    # 5.3s · claims OpenAI gpt-5 (frontier)
    - sambanova:deepseek-v3.1
    - github:gpt-4o-mini
    - groq:llama-4-scout
    - groq:gpt-oss-120b
    - openrouter:gpt-oss-120b-free
    - groq:gpt-oss-20b
    - mistral:large
    - zai:glm-4.5-flash
    - nvidia:qwen3.5-397b
    - pollinations:gpt-oss-20b
    - gigachat:2-pro
    - gigachat:2-max
    - openrouter:glm-4.5-air-free
    - cerebras:llama3.1-8b
    - groq:llama-3.3-70b
    - openrouter:ling-flash-free
    - cloudflare:llama-3.3-70b-fp8-fast
    - openrouter:gemma-3-27b-free
    - groq:qwen3-32b
    - groq:llama-3.1-8b-instant
    - gigachat:2
    - nvidia:llama-3.3-70b
    - sambanova:llama-3.3-70b
    - openrouter:free-router
    - github:llama-3.3-70b
    - gemini:flash-latest
    - github:deepseek-v3
    - openrouter:ling-1t-free
    # --- 2026-05-02 estimates additions (pending ru_bench, см. metrics в providers) ---
    - cohere:command-r-plus              # AA 22, RU 82, 1.2s — Cohere flagship trial (1K calls/мес shared)
    - cohere:command-r                   # AA 18, RU 80, 1.1s — Cohere R 35B
    - openrouter:gemma-4-31b-free        # AA 25, RU 78, 1.7s — NEW Gemma 4 dense, ctx 262k
    - openrouter:gemma-3-12b-free        # AA 13, RU 70, 2.1s
    - openrouter:nemotron-3-nano-omni-r-free  # AA 18, RU 70, 3.1s — reasoning + multimodal
    - openrouter:nemotron-3-nano-30b-free     # AA 18, RU 70, 4.0s — reasoning
    - cohere:command-r7b                 # AA 10, RU 70, 1.0s — tiny 7B
    - poolside:laguna-m.1                # ⭐ direct · SWE-Pro 47 / SWE-V 73 · 5s reasoning — Poolside flagship (release 2026-05-12)
    - poolside:laguna-xs.2               # direct · SWE-Pro 45 / SWE-V 68 · 4s reasoning — open 33B Apache 2.0
    - openrouter:laguna-m.1:free         # AA 14, RU 65, 2.1s — same model via OR :free (shared bucket)
    - openrouter:gpt-oss-20b-free        # AA 11, RU 65, 1.8s — same model groq:gpt-oss-20b
    - openrouter:gemma-3-4b-free         # AA 7,  RU 65, 2.2s
    - openrouter:gemma-4-26b-free        # AA 22, RU 75, ~3s — NEW Gemma 4 MoE (429-flaky upstream)
    - openrouter:qwen3-next-80b-free     # AA 24, RU 75, ~5s — Qwen3 Next 80B/3B MoE (429-flaky)
    - openrouter:hermes-3-405b-free      # AA 22, RU 60, ~30s — Hermes-3 на L3.1-405B (slow, 429-flaky)
    - openrouter:llama-3.3-70b-free      # AA 15, RU 60, ~5s (429-flaky)
    - openrouter:gemma-3n-e4b-free       # AA 6,  RU 55, 1.5s — nano 4B
    - openrouter:qwen3-coder-free        # AA 19, RU 55, ~5s — code-spec (429-flaky)
    - openrouter:gemma-3n-e2b-free       # AA 4,  RU 50, 1.4s — nano 2B
    - openrouter:llama-3.2-3b-free       # AA 8,  RU 45, ~2s (429-flaky)
    - openrouter:dolphin-venice-24b:free # AA 12, RU 45, ~5s — uncensored Mistral 24B (429-flaky)
    - openrouter:lfm-2.5-thinking:free   # AA 5,  RU 30 — tiny 1.2B reasoning, last-resort
    # --- FreeTheAi (⚠️ daily Discord /checkin required, circuit-breaker 60s)
    # gemini-2.5-flash и gpt-5 перенесены наверх, остальные оставлены последним резервом
    - freetheai:gpt-5-mini               # 5.6s, claims OpenAI/ChatGPT
    - freetheai:minimax-m2.7             # 5.2s, RU 75, reasoning (MiniMax-M2.7)
    - freetheai:kimi-k2.6                # 7.2s, RU 75, reasoning (Kimi-K2.6)
    - freetheai:glm-5.1                  # 8.7s, RU 80, reasoning (GLM-5.1, leaderboard #3)

  # --- chat_fast: chat minus всех с latency_s > 5s ---
  # Тот же порядок/приоритет что chat, но вычищены «долгодумы»:
  #   nvidia:qwen3.5-397b (72s), openrouter:minimax-m2.5-free (9.5s, reasoning),
  #   mistral:large (11.9s), github:gpt-4.1-mini (5.4s),
  #   nvidia:llama-3.3-70b (10.8s), github:llama-3.3-70b (13s),
  #   openrouter:glm-4.5-air-free (98s, reasoning),
  #   cloudflare:llama-3.3-70b-fp8-fast (18s), zai:glm-4.5-flash (74s, reasoning),
  #   openrouter:gpt-oss-120b-free (5.2s, reasoning), openrouter:free-router (20s).
  # Пороги строгие: ≤5s (sambanova:llama-3.3-70b на границе 5.0s — оставлен).
  chat_fast:
    # deepseek:v4-flash убран 2026-05-12 — см. комментарий в chain `chat`
    - github:gpt-4.1-mini
    - yandex:alice
    - gemini:2.5-flash-lite
    - sambanova:llama-4-maverick
    - freetheai:gemini-2.5-flash         # 4.1s · переехал из хвоста (circuit-breaker, 2026-05-08)
    - cerebras:qwen-3-235b
    - gemini:flash-lite-latest
    - gemini:2.5-flash
    - sambanova:deepseek-v3.2
    - sambanova:deepseek-v3.1
    - github:gpt-4o-mini
    - groq:llama-4-scout
    - groq:gpt-oss-120b
    - openrouter:gpt-oss-120b-free
    - groq:gpt-oss-20b
    - mistral:large
    - gigachat:2-pro
    - gigachat:2-max
    - cerebras:llama3.1-8b
    - groq:llama-3.3-70b
    - openrouter:ling-flash-free
    - cloudflare:llama-3.3-70b-fp8-fast
    - openrouter:gemma-3-27b-free
    - groq:qwen3-32b
    - groq:llama-3.1-8b-instant
    - gigachat:2
    - nvidia:llama-3.3-70b
    - sambanova:llama-3.3-70b
    - github:llama-3.3-70b
    - github:deepseek-v3
    - openrouter:ling-1t-free
    # --- 2026-05-02 estimates additions (latency ≤5s по smoke) ---
    - cohere:command-r                   # 1.1s, RU 80
    - cohere:command-r-plus              # 1.2s, RU 82
    - cohere:command-r7b                 # 1.0s, RU 70
    - openrouter:gemma-4-31b-free        # 1.7s, RU 78, AA 25 — NEW
    - openrouter:gpt-oss-20b-free        # 1.8s, RU 65
    - openrouter:gemma-3-12b-free        # 2.1s, RU 70
    - poolside:laguna-m.1                # direct · 5s reasoning · dedicated bucket
    - poolside:laguna-xs.2               # direct · 4s reasoning · dedicated bucket
    - openrouter:laguna-m.1:free         # 2.1s, RU 65 (shared OR :free bucket)
    - openrouter:gemma-3-4b-free         # 2.2s, RU 65
    - openrouter:gemma-3n-e4b-free       # 1.5s, RU 55
    - openrouter:gemma-3n-e2b-free       # 1.4s, RU 50
    - openrouter:nemotron-3-nano-omni-r-free # 3.1s, RU 70 — reasoning, остановит для chat_fast если важна скорость
    - openrouter:nemotron-3-nano-30b-free    # 4.0s, RU 70 — reasoning
    - openrouter:gemma-4-26b-free        # ~3s, RU 75 — 429-flaky
    # (freetheai:gemini-2.5-flash переехал в начало после circuit-breaker, 2026-05-08)

  # --- chat_strict_json: user-content validation with guaranteed strict JSON ---
  # Use case: structured validators (text moderation, classification, scoring),
  # где клиент делает JSON.parse(content) и не имеет strip-fences fallback.
  # Models filtered on (бенч 2026-05-12 на исламском UGC, n=5 на модель):
  #   1. Не отказывают на user-generated content (religion, marriage, identity, etc.).
  #   2. Возвращают чистый JSON без markdown-fences ```json…```.
  #   3. Median latency ≤ 3s для топ-8.
  # Порядок: accuracy-first (5/5 на длинном исламском тексте), latency-second.
  #
  # Excluded from chat/chat_fast (and why — все обнаружены на бенче 2026-05-12):
  #   - yandex:alice                    — plaintext refusal "Я не могу..." на ислам/брак
  #   - gemini:2.5-flash (full)         — цензурит религиозные декларации как policy violation
  #   - cohere:command-r, command-r7b   — выдумывают "objectionable language" verdicts
  #   - github:llama-3.3-70b            — flag religious references как invalid
  #   - groq:llama-3.3-70b              — требует "objective format", invalid на нормальном тексте
  #   - sambanova:llama-4-maverick      — "Ненадлежащее содержание" на benign UGC
  #   - sambanova:deepseek-v3.1         — 0/5 "prohibited content: religious reference"
  #   - gigachat:2-max, gigachat:2-pro  — 0/5: отказывают на длинном тексте под "non-ASCII chars"
  #     (на коротких фразах работают, на длинных — censorship-режим)
  #   - openrouter:nemotron-3-nano-30b-free — false-negatives на коротком тексте
  #   - github:deepseek-v3              — wraps in ```json fences
  #   - gemini:2.5-flash-lite           — иногда wraps в ```json fences (~30%)
  #   - openrouter:*-free (gemma-3*, gemma-3n-*, gemma-4-26b, hermes-3, ling-*,
  #     llama-3.*-free, qwen3-coder, qwen3-next, minimax-m2.5, dolphin-venice)
  #                                     — upstream 404 "No endpoints found"
  #   - nvidia:qwen3.5-397b             — 45s timeouts
  #   - cloudflare:llama-3.3-70b-fp8-fast — latency variance 1.7s → 24s
  #   - sambanova:deepseek-v3.2         — upstream maintenance (503)
  chat_strict_json:
    - groq:gpt-oss-20b                  # 1.0s · 5/5 · best balance speed+accuracy
    - groq:gpt-oss-120b                 # 1.0s · 5/5 · топ качество
    - github:gpt-4.1-mini               # 1.7s · 5/5 · стабильный (был дефолт chat_fast)
    - mistral:large                     # 1.1s · 4/5 · 1 transient parse error
    - github:gpt-4o-mini                # 2.0s · 5/5
    - cohere:command-r-plus             # 0.8s median (до 8s tail) · 5/5
    - zai:glm-4.5-flash                 # 3.1s · 5/5
    - gemini:flash-latest               # 2.9s · 5/5
    - groq:llama-4-scout                # 0.6s · 4/5 · fastest, иногда false-neg на длинных RU
    - openrouter:gpt-oss-120b-free      # 3–14s · hard fallback (free)
    - freetheai:gemini-2.5-flash        # 17s · last resort (медленный, но не отказывает)

