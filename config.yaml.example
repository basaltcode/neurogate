  # Kimi K2 Instruct на Groq LPU — 262K context, очень дешёвая alt для кодинга/long-ctx.
  # awesome-free-llm-apis 2026-05: 30 RPM, 14,400 RPD (стандартный Groq free).
  - name: groq:kimi-k2-instruct
    kind: groq
    model: kimi-k2-instruct
    api_key_env: GROQ_API_KEY
    rpm: 30
    rpd: 14400
    quality: 0     # estimate — Moonshot Kimi K2 (общий уровень близок к Mistral Large)
    latency_s: 0   # estimate — Groq LPU, ожидаемо <2s
    ru: 0          # estimate — нужен прогон

  # DeepSeek-R1 distill 70B на Groq — reasoning через LPU.
  - name: groq:deepseek-r1-distill-70b
    kind: groq
    model: deepseek-r1-distill-llama-70b
    api_key_env: GROQ_API_KEY
    rpm: 30
    rpd: 14400
    timeout: 120
    quality: 0     # estimate — R1 distill 70B
    latency_s: 0   # estimate
    ru: 0          # estimate
    reasoning: true

  - name: cerebras:llama3.1-8b
    kind: cerebras
    model: llama3.1-8b
    api_key_env: CEREBRAS_API_KEY
    rpm: 30
    rpd: 14400  # per-model RPD
    quality: 12
