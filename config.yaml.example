    - openrouter:qwen3-coder-free        # AA 19 (429-flaky)
    - openrouter:nemotron-3-nano-30b-free # AA 18 reasoning
    - openrouter:nemotron-3-nano-omni-r-free # AA 18 reasoning multimodal
    - poolside:laguna-m.1                # direct · SWE-V 73 · reasoning · dedicated bucket
    - poolside:laguna-xs.2                # direct · SWE-V 68 · open 33B
    - openrouter:laguna-m.1:free         # AA 14 Poolside (shared OR :free)
    - openrouter:gemma-3-12b-free        # AA 13
    - openrouter:dolphin-venice-24b:free # AA 12 uncensored
    - openrouter:gpt-oss-20b-free        # AA 11
    - cohere:command-r7b                 # AA 10
    - openrouter:llama-3.3-70b-free      # AA 15 (429-flaky)
    - openrouter:llama-3.2-3b-free       # AA 8 (429-flaky)
    - openrouter:gemma-3-4b-free         # AA 7
    - openrouter:gemma-3n-e4b-free       # AA 6
    - openrouter:gemma-3n-e2b-free       # AA 4
    - openrouter:lfm-2.5-thinking:free   # AA 5 reasoning

  # --- reasoning_quality: 9 подтверждённых thinking-моделей, порядок по AA Index v4.0 ---
  # Когда нужен умный ответ на сложную задачу: порядок — от максимального качества к минимальному.
  # Все провайдеры подтверждены через reasoning-детектор 2026-04-21 (thoughts/reasoning_tokens > 0).
  reasoning_quality:
    - gemini:flash-latest              # AA 46, thoughts=260
    - openrouter:nemotron-3-super-free # AA 35, r_tok=58
    - openrouter:minimax-m2.5-free     # AA ~35, r_tok=290-465 (reasoning, 2026-04-22)
    - groq:gpt-oss-120b                # AA 33, r_tok=129 (быстрый — 0.7s)
    - openrouter:gpt-oss-120b-free     # AA 33, r_tok=18 (backup через OR)
    - groq:gpt-oss-20b                 # AA 25, r_tok=192
    - pollinations:gpt-oss-20b         # AA 25, same GPT-OSS 20B Reasoning via OVH (no-auth backup)
    - openrouter:glm-4.5-air-free      # AA 24, r_tok=302
    - gemini:2.5-flash                 # AA 21, thoughts=743
    - zai:glm-4.5-flash                # AA 20, r_tok=437 (самое глубокое thinking, но 25s)
    - groq:qwen3-32b                   # AA 17, inline <think>, 716 tokens
    # --- 2026-05-02 estimates additions (новые reasoning-модели) ---
    - openrouter:nemotron-3-nano-omni-r-free # AA 18, reasoning + multimodal, 3.1s
    - openrouter:nemotron-3-nano-30b-free    # AA 18, reasoning, 4.0s
    - openrouter:lfm-2.5-thinking:free       # AA 5, tiny 1.2B reasoning — last-resort

  # --- reasoning_deep: те же 9, порядок по глубине thinking (thoughts/reasoning_tokens на "корзина фруктов" 2026-04-21) ---
  # Когда важен САМ факт длительного рассуждения (сложные многошаговые задачи, CoT-heavy).
  # Первыми идут провайдеры, которые думают дольше/глубже — не обязательно дают лучший ответ.
  reasoning_deep:
    - gemini:2.5-flash                 # thoughts=743
    - groq:qwen3-32b                   # inline <think>, 716 total tokens
    - zai:glm-4.5-flash                # r_tok=437, r_content=1205ch
    - openrouter:minimax-m2.5-free     # r_tok=290-465 avg ~378 (OpenInference, 2026-04-22)
    - openrouter:glm-4.5-air-free      # r_tok=302, r_content=870ch
    - gemini:flash-latest              # thoughts=260
    - groq:gpt-oss-20b                 # r_tok=192, r_content=625ch
    - pollinations:gpt-oss-20b         # reasoning-heavy backend (OVH) — видим reasoning_content в response
    - groq:gpt-oss-120b                # r_tok=129, r_content=409ch
    - openrouter:nemotron-3-super-free # r_tok=58, r_content=220ch
    - openrouter:gpt-oss-120b-free     # r_tok=18 (легче чем groq-вариант — разные backends)

  # --- web: провайдеры с подтверждённым веб-поиском (bench_web2.py 2026-04-21) ---
  # Роутер при chain=web передаёт web_search=True, провайдер инжектит нативный tool:
  #   - gemini → google_search (grounding_metadata с URL-цитатами)
  #   - groq gpt-oss → browser_search (server-side Groq compound)
  # OpenRouter :online-варианты исключены: Exa-поиск у OR стоит $4/1000 и требует
  # PAID-ключа — правило «PAID только для Opus» (см. paid chain). Их определения
  # в providers остались (не используются ни одной цепочкой), при необходимости
  # можно собрать отдельную платную `web_paid` цепочку.
  # Порядок: quality desc, latency tiebreak.
  web:
    - gemini:flash-latest                   # Gemini 3 Flash · AA 46 · 3.6s · google_search
    - gemini:flash-lite-latest              # Gemini 3.1 FL · AA 34 · 3.6s · google_search
    - groq:gpt-oss-120b                     # AA 33 · 1.3s · browser_search tool
    - groq:gpt-oss-20b                      # AA 25 · 0.7s · browser_search tool
    - gemini:2.5-flash-lite                 # AA 13 · 2s · google_search, последний резерв

  # --- translation: перевод через /v1/translate — 4 dedicated MT + 1 LLM safety net ---
  # Все 5 бесплатны permanent. Топ-4 — специализированные переводчики, 5-й —
  # catastrophic fallback если первые 4 одновременно упали (реально — ~никогда).
  # Если нужен LLM-перевод по контексту — использовать `model=<llm-name>` явно.
  # Почему здесь нет остальных LLM-ов: цепочка была чищена 2026-04-24 после того как
  # user заметил что 13 LLM-фоллбэков дают >0 ценности в normal flow — dedicated MT
  # работают так надёжно что LLM-слой никогда не активируется.
  translation:
    - yandex:translate                 # Yandex Translate · 0.5s · RU 90 ★★★★★ · 1M chars/мес permanent
    - cohere:aya-expanse-32b           # Cohere Aya Expanse 32B · 1.1s · RU 82 · 102 langs · 1K calls/мес permanent
    - libretranslate:fedilab           # LibreTranslate fedilab-mirror · 0.5s · RU 70 · без ключа, unlimited
    - mymemory:free                    # MyMemory TM · 1.1s · RU 74 · 5K chars/day anon permanent
    # LLM safety net: бесплатные сначала, грант/Freemium-квота — последними.

  # --- translate_adaptive: 4 проверенных провайдера + динамический порядок ---
  # Бенч 2026-04-29 (3 сценария × 7 моделей). Из исходных 7 годятся 4:
  #   yandex:translate    — 0.7s, чисто, иногда теряет имена
  #   cohere:aya-expanse  — 5.7s, лучшее качество (включая арабский)
  #   libretranslate      — 1.4s, приемлемо, арабский слабый
  #   cerebras:qwen-3-235b — 2.8s, упал на турецком (1/3 fail) → fallback only
  # Выкинуты: mymemory (502), gigachat (смешивает кириллицу), yandexgpt (отказ на религии).
  #
  # Адаптивный порядок (router.translate):
  #   • если ru ∈ {source, target} → yandex:translate первым (быстрее и точнее на RU)
  #   • иначе                       → cohere:aya-expanse-32b первым (лучшее качество)
  # Остальные сохраняют порядок ниже как fallback.
  translate_adaptive:
    - yandex:translate
    - cohere:aya-expanse-32b
    - libretranslate:fedilab
    - mymemory:free                    # MyMemory TM · 1.1s · RU 74 · 5K chars/day anon permanent

  # --- paid: единственная платная модель через OpenRouter (для тестов и прочего не трогать без явного разрешения)---
  paid:
    - openrouter:claude-opus-4.7      # Anthropic Claude Opus 4.7 via OpenRouter (платная)
    - openai:gpt-5-mini               # OpenAI gpt-5-mini · $0.25/$2.00 per 1M · $5 аккаунт
    - deepseek:v4-pro                 # DeepSeek V4-Pro PAYG · $0.435/$0.87 (-75% до 2026-05-31) · SWE-V 80.6%, 1M ctx
    - deepseek:v4-flash               # DeepSeek V4-Flash PAYG · $0.14/$0.28 (-75% до 2026-05-31) · 1M ctx, fast

  # --- audio: Speech-to-Text. Whisper на Groq (быстро, эталон RU) + Gemini multimodal last-resort ---
  # Через /v1/audio/transcriptions (OpenAI-compat multipart). model=audio → цепочка.
  # Groq Whisper — чисто транскрипция, не участвует в chat. Gemini — инжектит audio через
  # inline_data в generate_content (медленнее, но делит квоту с chat-цепочкой).
  audio:
    - groq:whisper-large-v3-turbo      # 0.62s · RU 95 · default
    - groq:whisper-large-v3            # 0.56s · RU 98 · чуть точнее, fallback
    - gemini:flash-latest              # 3.4s · RU ~90 · last-resort через multimodal

  # --- tts: Text-to-Speech через /v1/audio/speech ---
  # Sync, возвращает raw audio bytes (audio/mpeg для mp3) как у OpenAI tts-1.
  # На данный момент один провайдер — Edge TTS (безлимит, без ключа).
  # Voice = `ru-RU-DmitryNeural` / `en-US-AriaNeural` / любой Edge voice name
  # (или OpenAI-совместимые alloy/echo/fable/onyx/nova/shimmer → en-US map).
  tts:
    - edge:tts                         # безлимит, mp3-only, 400+ голосов

  # --- sfx: Sound effects / ambient через /v1/audio/sfx ---
  # Один провайдер — публичный HF Space artificialguybr/Stable-Audio-Open-Zero
  # (gradio_client). Bottleneck — анонимная Zero-GPU квота ~1-2 вызова/день/IP;
  # с HF_TOKEN (free) per-account и чуть выше, с PRO — практически снимается.
  # Не путать с tts (синтез голоса) и audio (STT).
  sfx:
    - hfspace:stable-audio-open        # Stable Audio Open, до ~47с loop-able

  # --- image_gen: text→image через /v1/images/generations ---
  # Sync, возвращает {data:[{b64_json}|{url}]} как у OpenAI DALL-E.
  # Порядок fallback (бенч 2026-04-22, 512×512):
  #   1. Быстрые с независимыми пулами квот (Pollinations seed → CF)
  #   2. Gemini (currently 429, но fail-fast 0.7s — оставлен на случай возврата free tier)
  #   3. Медленные fallback (Pollinations flux/turbo, AI Horde — community-distributed)
  # Исключены:
  #   together:flux-schnell-free — signup credits исчерпаны (HTTP 402)
  #   pollinations:kontext — требует enter.pollinations.ai tier
  image_gen:
    # Бенч 2026-04-26 (768×768, single-shot + 5-probe replay). Порядок: успешные
    # провайдеры по возрастанию реальной латентности, всегда-фейлящие — в хвост.
    # NB: Pollinations seed-tier (sana/flux/turbo) — все на одной общей очереди
    # ~60-90с. Замеры 1.5s/58s в первом прогоне были попаданием в их prompt-кэш;
    # 5-probe replay показал стабильные 89с на холодных промптах. Поэтому sana
    # — после CF, не впереди.
    - cloudflare:flux-1-schnell        # 2.7s · FLUX.1 schnell · CF 10K neurons/день
    - cloudflare:sdxl-lightning        # 3.2s · SDXL Lightning · CF (общий пул neurons)
    - cloudflare:phoenix               # 3.8s · Leonardo Phoenix 1.0 · CF (общий пул neurons)
    - cloudflare:dreamshaper           # 5.0s · DreamShaper LCM · CF (общий пул neurons)
    - yandex:art                       # 10.6s · YandexART · 2.24 ₽/img из гранта 6К (~2680 картинок)
    - gigachat:kandinsky               # 14.9s · Kandinsky 3.1 через GigaChat (1-3K токенов из 1М PERS)
    - pollinations:sana                # ~89s · Sana · pollinations seed queue (cache hit ~2s)
    - pollinations:flux                # ~89s · FLUX · общая seed queue с sana/turbo
    - pollinations:turbo               # ~89s · Z-Image Turbo 6B · общая seed queue
    # ↓ FreeTheAi (⚠️ daily Discord /checkin required, +download для vhr/* URLs)
    - freetheai_image:seedream_v4      # 15.5s · Bytedance Seedream v4 · vhr-proxy, b64-converted
    - freetheai_image:flux_dev         # 17s · FLUX dev · vhr-proxy
    - freetheai_image:gpt_image_2      # 21s · OpenAI gpt-image-2 native b64 (часто 429 от upstream)
    - freetheai_image:nano_banana_2    # 22.7s · Nano Banana 2 · vhr-proxy
    - freetheai_image:gpt_image_2_vhr  # 30.5s · gpt-image-2 через Vheer-прокси
    # ↓ всегда-фейлящие, держим в хвосте на случай восстановления квот/кудосов
    - gemini:nano-banana               # 429 fail-fast 2.5s (free tier limit=0 на 2026-04-26)
    - aihorde:dreamshaper              # 403 на >648×648 (anonymous tier требует kudos)
    - aihorde:flux-schnell             # >300s timeout · AI Horde Flux schnell community queue
    - aihorde:sdxl                     # >300s timeout · AI Horde SDXL community queue

  # --- image_edit: редактирование готовой картинки (b64-вход, b64-выход) ---
  # На 2026-05-08 единственный поддерживающий провайдер во всём роутере —
  # FreeTheAi с моделью img/gpt-image-2 (под капотом OpenAI gpt-image-2).
  # Cloudflare/Yandex/GigaChat/Pollinations/Together/AIHorde — gen-only.
  # ⚠️ FreeTheAi требует daily Discord /checkin и часто ловит 429 от общего пула.
  image_edit:
    - freetheai_image:gpt_image_2      # img/gpt-image-2 — b64 native ~650KB PNG

  # --- moa: Mixture of Agents (Wang et al., 2024). Параллельный fan-out к УНИКАЛЬНЫМ моделям → aggregator синтезирует ---
  # По одному провайдеру на каждое модельное семейство (самый быстрый/надёжный хостер).
  # Дубликаты моделей исключены: groq:gpt-oss-120b предпочтён openrouter:gpt-oss-120b-free (1.3s vs 5.2s);
  # groq:llama-3.3-70b предпочтён всем остальным хостерам llama-3.3 (2.2s vs 5-18s).
  # Opus (paid) и openrouter:free-router (lottery/duplicate) НЕ включены.
  # Aggregator по умолчанию — цепочка reasoning_quality (override: ?aggregator=<chain>).
  # Название "moa" ≠ "swarm": swarm в строгом смысле — emergent coordination между агентами
  # (как муравьи/пчёлы). MoA — иерархический ансамбль без inter-agent comm. Будущая цепочка
  # debate добавит настоящее multi-agent взаимодействие.
  moa:
    - gemini:flash-latest              # Gemini 3 Flash · AA 46 · reasoning · 3.6s
    - sambanova:deepseek-v3.2          # DeepSeek V3.2 · AA 46 (reasoning по AA) · 3.4s
    - gigachat:2-max                   # GigaChat-2-Max · ~AA 40 · RU 93 · 2.4s · уникальная RU-native семья
    - yandex:alice                 # YandexGPT Pro 5.x · ~AA 25 · RU 88 · 0.7s · уникальная RU-native (Yandex)
    - nvidia:qwen3.5-397b              # Qwen 3.5 397B · AA 40 · RU 92 · 72s
    - openrouter:nemotron-3-super-free # Nemotron 3 Super · AA 35 · reasoning · 20s
    - openrouter:minimax-m2.5-free     # MiniMax M2.5 · AA ~35 · reasoning · 196k ctx · 9.5s
    - gemini:flash-lite-latest         # Gemini 3.1 Flash Lite · AA 34 · 2.6s
    - groq:gpt-oss-120b                # GPT-OSS 120B · AA 33 · reasoning · 1.3s
    - cerebras:qwen-3-235b             # Qwen 3 235B · AA 30 · reasoning · 1.1s
    - openrouter:ling-1t-free          # InclusionAI Ling 2.6 1T MoE · AA ~30 · 262k ctx · 2.6s
    - sambanova:deepseek-v3.1          # DeepSeek V3.1 · AA 28 · 3.2s
    - groq:gpt-oss-20b                 # GPT-OSS 20B · AA 25 · reasoning · 0.7s
    - openrouter:glm-4.5-air-free      # GLM 4.5 Air · AA 24 · reasoning · 98s
    - mistral:large                    # Mistral Large 3 · AA 23 · 11.9s
    - github:gpt-4.1-mini              # GPT-4.1 mini · AA 23 · 5.4s
    - github:deepseek-v3               # DeepSeek V3 (0324) · AA 22 · 4.6s
    - gemini:2.5-flash                 # Gemini 2.5 Flash · AA 21 · reasoning · 3.5s
    - openrouter:gemma-3-27b-free      # Gemma 3 27B · AA 20 · 3.1s
    - zai:glm-4.5-flash                # GLM 4.5 Flash · AA 20 · reasoning · 74s
    - openrouter:ling-flash-free       # InclusionAI Ling 2.6 · AA ~18 · 262k ctx · 1.2s
    - groq:qwen3-32b                   # Qwen 3 32B · AA 17 · reasoning · 1.3s
    - sambanova:llama-4-maverick       # Llama 4 Maverick · AA 17 · 1.6s
    - nvidia:nemotron-llama-49b        # Nemotron Llama 49B · AA 15 · 27s
    - groq:llama-3.3-70b               # Llama 3.3 70B (fastest host) · AA 15 · 2.2s
    - groq:llama-4-scout               # Llama 4 Scout · AA 14 · 0.9s
    - gemini:2.5-flash-lite            # Gemini 2.5 Flash Lite · AA 13 · 2.6s
    - github:gpt-4o-mini               # GPT-4o mini · AA 13 · 3.9s
    - cerebras:llama3.1-8b             # Llama 3.1 8B (fastest) · AA 12 · 0.4s

  # --- sc: Self-Consistency (Wang et al., 2022). N сэмплов ОДНОЙ модели + aggregator ---
  # Первый провайдер — base-модель, от которой берём N сэмплов (default N=5, override ?samples=N).
  # Остальные — fallback если первая упала. При желании поменять base-модель:
  # либо отредактируй порядок, либо ?base=<provider:name> в запросе.
  # Aggregator по умолчанию — reasoning_quality (override: ?aggregator=<chain>).
  sc:
    - gemini:flash-latest              # base: AA 46, reasoning, 1M ctx, RPD 250 — хватит на 5× за раз
    - sambanova:deepseek-v3.2          # fallback base: AA 46 reasoning, rpd 20 — маловато для samples=5
    - groq:gpt-oss-120b                # fallback base: AA 33, reasoning, 30 RPM — ок для N=5

  # --- debate: Multi-Agent Debate (Du et al. 2023, Liang et al. 2023) ---
  # N разных моделей × R раундов inter-agent revision. Раунд 0: каждый агент
  # отвечает независимо. Раунды 1..R-1: агент видит ответы коллег и переписывает
  # свой с учётом критики. Финальный synth — aggregator (как в moa).
  # Параметры: ?agents=N (2-6, default 3), ?rounds=R (1-4, default 2),
  # ?aggregator=<chain> (default reasoning_quality).
  # Берутся первые ?agents= eligible провайдеров — порядок задаёт состав. Идеал:
  # разные семьи моделей для диверсификации. Пул покрывает 10 школ:
  # Google · DeepSeek · Qwen (Alibaba) · OpenAI-OSS · Meta Llama · Mistral (EU) ·
  # NVIDIA Nemotron · Cohere · Tencent Hunyuan · MiniMax. Длиннее ?agents= — fallback.
  debate:
    - gemini:flash-latest              # Google Gemini 3 Flash · AA 46 · reasoning · 3.6s
    - sambanova:deepseek-v3.2          # DeepSeek V3.2 · AA 46 reasoning · 3.4s
    - cerebras:qwen-3-235b             # Qwen 3 235B (Alibaba) · AA 30 · reasoning · 1.1s
    - groq:gpt-oss-120b                # OpenAI GPT-OSS 120B · AA 33 · reasoning · 1.3s
    - groq:llama-3.3-70b               # Meta Llama 3.3 70B · AA 15 · 2.2s · 1000 RPD
    - mistral:large                    # Mistral Large 3 (EU) · AA 23 · 11.9s · rpm 4
    - openrouter:nemotron-3-super-free # NVIDIA Nemotron 3 Super · AA 35 · reasoning · 20s
    - cohere:aya-expanse-32b           # Cohere Aya 32B · multilingual · trial 1000/мес
    - openrouter:hy3-preview:free      # Tencent Hunyuan 3 Preview 295B MoE · reasoning · free
    - openrouter:minimax-m2.5-free     # MiniMax M2.5 · reasoning · free 1000 RPD

  # --- deep_search: research-агент. Plan → Search × N → Synthesize → Critique → (доп. round если есть пробелы) ---
  # Цепочка-плейсхолдер: реальная логика внутри deep_search.py использует разные
  # цепочки для каждой роли:
  #   Planner/Synthesizer/Critic → reasoning_quality (override: ?planner=, ?synth=, ?critic=)
  #   Searcher → web (gemini:flash-latest с google_search + OR :online провайдеры)
  # В /v1/models должна быть видна как "deep_search", поэтому один провайдер тут нужен.
  deep_search:
    - gemini:flash-latest              # placeholder: default synthesizer (реально резолвится через reasoning_quality)

  # --- embed: текстовые embeddings через /v1/embeddings ---
  # Voyage первым: 200M tok permanent на каждую модель — независимый от chat бакет,
  # переживает любую индексацию. Gemini после Voyage — лучший RU, но shared 1500 RPD
  # с chat-Gemini, поэтому не первый. Cloudflare bge-m3 last-resort: качество ниже,
  # но 10K neurons/день переживёт всё что упало выше.
  # Pass-through extras в запросе:
  #   `dimensions: N` — MRL truncation (Voyage 256–2048, Jina v5/Gemini 768/1536/3072)
  #   `task: retrieval.query|retrieval.passage` — Jina v3+
  #   `input_type: search_query|search_document` — Cohere/Voyage
  embed:
    - voyage:voyage-3.5                # 1024d · 200M tok permanent · MTEB-multi top
    - jina:embeddings-v5-text-small    # 1024d · 10M tok pool · 89 langs
    - voyage:voyage-3-large            # 1024d · 200M tok · сильнее на сложных запросах
    - voyage:voyage-3.5-lite           # 1024d · 200M tok · быстрее/дешевле
    - cohere:embed-v4                  # 1536d · 1000/мес trial · SOTA mLLM
    - gemini:embedding-001             # 3072d · 1500 RPD shared with chat — поэтому не первый
    - cohere:embed-multilingual-v3     # 1024d · 1000/мес trial
    - jina:embeddings-v3               # 1024d · backup если v5 затупит
    - mistral:embed                    # 1024d · Experiment 1B shared с chat-Mistral
    - github:text-embedding-3-large    # 3072d · Copilot-free, 50 RPD per-model
    - github:text-embedding-3-small    # 1536d · 150 RPD per-model
    - nvidia:nv-embedqa-e5-v5          # 1024d · 512 ctx (узкое горлышко) · NIM 1000 credits
    - cloudflare:bge-m3                # 1024d · 10K neurons last-resort

  # --- embed_code: код-embeddings через /v1/embeddings ---
  # Voyage code-3 — SOTA на code-search (MTEB-Code 2025). Jina 1.5b новейший
  # (декабрь 2025). Codestral третьим — shared с chat-Mistral, не выжигает отдельный
  # бакет. v2-base-code — last-resort, проверенный с 2024.
  embed_code:
    - voyage:voyage-code-3             # 1024d · 200M tok permanent · MTEB-Code SOTA
    - jina:code-embeddings-1.5b        # 1536d · 10M tok pool · новейший
    - mistral:codestral-embed          # 1536d · Experiment shared
    - jina:embeddings-v2-base-code     # 768d · last-resort

  # --- rerank: cross-encoder поверх top-N от embed (второй этап RAG) ---
  # Jina v3 первым: SOTA multilingual + 131K ctx + 10M tok pool (тот же что Reader/embed).
  # Cohere v3.5 вторым — SOTA на EN, но 1000/мес trial-bucket → не выжигаем сразу.
  # Voyage 2.5 третьим: 200M tok permanent независимый бакет, 32K ctx (длинные доки).
  # Jina v2 / Voyage lite — последние fallback'и.
  # Pass-through extras в запросе:
  #   `top_n: N` (Voyage = top_k, нормализуется автоматически)
  #   `return_documents: true` — вернуть text оригинальных документов
  rerank:
    - jina:reranker-v3                 # 88 · 131K ctx · 10M tok pool · multilingual SOTA
    - cohere:rerank-v3.5               # 85 · 4K ctx · 1000/мес trial · RU 90
    - voyage:rerank-2.5                # 80 · 32K ctx · 200M tok permanent
    - jina:reranker-v2-base-multilingual  # 78 · 8K ctx · backup v2
    - voyage:rerank-2.5-lite           # 70 · last-resort

  # --- moderation: text-only через /v1/moderations ---
  # OpenAI omni первый — единственный с native scores и 13 категорий, бесплатно навсегда.
  # Mistral второй — multilingual native scores, RU 80. Cloudflare Llama Guard 3-8B
  # последний independent-pool fallback (10K neurons/день).
  # Together-провайдеры в config есть, но не в default chain: на 2026-04-25 их
  # ключ user'а упёрся в 402 credit_limit. Раскомментируй когда credits появятся.
  moderation:
    - openai:moderation                # 13 cats + scores · 0.4s · multimodal · permanent free
    - mistral:moderation               # 9 cats + scores · 0.5s · RU 80
    - openai:text-moderation           # 7 cats · 0.3s · legacy text-only · permanent free
    - cloudflare:llama-guard-3-8b      # 0.8s · 10K neurons/день · text-only S-codes

  # --- moderation_image: только мультимодальные классификаторы ---
  # OpenAI omni-moderation = единственный реально работающий multimodal slot
  # для текущих ключей user'а. Together Llama Guard 4 multimodal закомментирован
  # (нужны Together credits).
  moderation_image:
    - openai:moderation                # SOTA, native scores, 13 cats, multimodal
    # - together:llama-guard-4         # раскомментировать когда у Together будут credits

  # --- moderation_jailbreak: prompt-injection / jailbreak detection ---
  # Prompt Guard 2 86M — узкий специалист (бинарный verdict). OpenAI omni и
  # Mistral как safety net на случай редких EN-bypass'ов которые prompt-guard
  # пропустит. Groq Llama-Guard-4 decommissioned 2026-04, заменён prompt-guard-2.
  moderation_jailbreak:
    - groq:prompt-guard-2-86m          # 0.4s · EN, narrow prompt-injection detector
    - openai:moderation                # widely-trained safety net (13 cats)
    - mistral:moderation               # dangerous_and_criminal_content / pii fallback

  # --- moderation_ru: RU/AR-критичные домены (KSA-compliance, Sber-сценарии) ---
  # Mistral первый (RU 80, native scores), OpenAI вторым (multilingual, RU 85),
  # CF Llama Guard 3-8B как backup. Qwen3-Guard на Together (RU 85) — закомментирован
  # пока нет credits.
  moderation_ru:
    - mistral:moderation               # RU 80 · native scores · 9 cats
    - openai:moderation                # RU 85 · 13 cats · multimodal
    - cloudflare:llama-guard-3-8b      # RU 60 · backup, S-codes
    # - together:qwen3-guard           # RU 85 · 100+ языков (нужны Together credits)

