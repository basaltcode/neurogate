    vision: true

  - name: cloudflare:qwq-32b
    kind: cloudflare
    model: "@cf/qwen/qwq-32b"
    api_key_env: CLOUDFLARE_API_KEY
    rpd: 300
    timeout: 180
    quality: 0
    latency_s: 0
    ru: 0
    reasoning: true

  - name: cloudflare:deepseek-r1-distill-32b
