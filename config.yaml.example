    kind: nvidia
    model: meta/llama-3.3-70b-instruct
    api_key_env: NVIDIA_API_KEY
    rpm: 40
    quality: 15
    latency_s: 10.767
    ru: 60        # bench: 12/20 (auto, 2.56s avg)

  - name: github:llama-3.3-70b
    kind: github
