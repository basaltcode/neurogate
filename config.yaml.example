    timeout: 240
    quality: 50      # estimate — SWE-Pro 46.9% / SWE-V 72.5% / TB2 40.7% (225B-A23B MoE, между Pro/V3.2 и frontier)
    latency_s: 5.0   # smoke 2026-05-12 (reasoning, 156 r_tok / 271 out)
    ru: 70           # estimate (extrap из openrouter:laguna-m.1:free = 65)
    reasoning: true

