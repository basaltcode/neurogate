    - nvidia:qwen3.5-397b             # AA 40 · RU 92 · rpm 40
    - gigachat:2                      # ~AA 30 · RU 90 · нет RPD/RPM
    - mistral:large                   # AA 23 · RU 73 · rpm 4
    - zai:glm-4.5-flash               # AA 20 · RU 43 · без лимитов
    - nvidia:llama-3.3-70b            # AA 15 · RU 48 · rpm 40
    - nvidia:nemotron-llama-49b       # AA 15 · RU 18 · rpm 40

  # --- quota: бесплатные RU-провайдеры с ограниченной квотой (грант/PERS-tier) ---
  # Yandex AI Studio (общий баланс с translate/art/vision).
  # GigaChat PERS — 1M токенов на 30 дней per-account (общий пул на 2/2-pro/2-max).
  # Использовать когда нужна сильная RU-генерация и unlimited-цепочка не тянет.
  # Порядок: RU desc → quality → latency.
  quota:
    - yandex:alice                    # q35 · RU 90 · 0.8s · грант 6К ₽
    - gigachat:2-max                  # q40 · RU 70 · 2.4s · 1M tok/мес
    - gigachat:2-pro                  # q35 · RU 70 · 1.9s · общий пул
    - gigachat:2                      # q30 · RU 60 · 1.6s · общий пул

  # --- image: vision-capable провайдеры, порядок по точности описаний ---
  # Тест 2026-04-21: 111.jpg (кот на скейте) + 222.jpg (Стич с лягушкой, Disney).
  # Исключены: mistral:large (silent-ignore image_url, галлюцинирует — на 222.jpg
  # ответил «Немо и Дори»), sambanova:llama-3.3-70b (слепая галлюцинация «кошка»),
  # остальные text-only, все OR :free без vision endpoints, nvidia:qwen3.5-397b
  # (TIMEOUT 90s), openrouter:claude-opus-4.7 (paid — вручную через `paid` chain).
  image:
    - sambanova:llama-4-maverick      # детальный, распознаёт водяные знаки (AVATARKO.RU)
    - gemini:flash-lite-latest        # точный + контекст (3D-стиль, обои/аватарка), 14-18s
    - github:gpt-4.1-mini             # точный, средней детальности, ~5s
    - github:gpt-4o-mini              # точный, краткий, ~5s
    - gemini:2.5-flash-lite           # точный + быстрый (1.7s)
    - groq:llama-4-scout              # самый быстрый (0.8s), точный, иногда путает детали
    - gemini:2.5-flash                # ⚠️ обрезается — thinking ест max_output_tokens
    - gemini:flash-latest             # ⚠️ обрезается — thinking ест max_output_tokens
    - openrouter:gemma-3-27b-free     # vision-capable, но upstream 429 (2/2 fail в тестах)
    - openrouter:free-router          # last-resort lottery, кривая кириллица

