  - name: zai:glm-4.5-flash
    kind: zai
    model: glm-4.5-flash
    api_key_env: ZAI_API_KEY
    timeout: 180   # v2 бенч 74s total, 33s TTFT — долго думает перед content
    quality: 20   # AA Index v4.0 (~)
    latency_s: 74.203
    ru: 75        # bench: 15/20 (auto, 13.77s avg)
    reasoning: true   # подтверждено 2026-04-21: reasoning_tokens=437, r_content=1205ch — самый тяжёлый thinker

