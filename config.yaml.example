    rpd: 100
    quality: 0     # estimate — GLM-4.7-Flash class
    latency_s: 0   # estimate — Cerebras LPU
    ru: 0          # estimate

  # === OR :free добавлены 2026-04-20 по OR_FREE_SCAN.md ===
  # Прямые qwen3-next-80b/qwen3-coder/gemma-4-31b через OR :free — 100% 429 (upstream дохлый).
  # Выбраны живые: gpt-oss-120b-free (3/3, OpenInference backend), gemma-3-27b-free (2/3, Google AI Studio).
  # Плюс free-router как last-resort — распределяет по живым backend'ам (3/3 в ping, 5/5 в бенче).

  - name: openrouter:gpt-oss-120b-free
    kind: openrouter
    model: openai/gpt-oss-120b:free
    api_key_env: OPENROUTER_API_KEY
    rpm: 20
    rpd: 1000   # shared bucket на все OR :free
    timeout: 120
    quality: 33   # AA Index v4.0 (=groq:gpt-oss-120b), backup через OpenInference
    latency_s: 5.199
    ru: 80        # bench: 16/20 (auto, 4.99s avg)
    reasoning: true   # подтверждено 2026-04-21: reasoning_tokens=18, r_content=72ch (меньше чем groq, но reasoning-модель)

  - name: openrouter:gemma-3-27b-free
    kind: openrouter
    model: google/gemma-3-27b-it:free
    api_key_env: OPENROUTER_API_KEY
    rpm: 20
    rpd: 1000
    timeout: 120
    tools: false   # Gemma family не имеет нативного function calling
    quality: 20   # Gemma 3 27B, 140 языков официально Google, приличный RU
    latency_s: 3.118   # flaky 2/3 OK — под нагрузкой 429
    ru: 65        # bench: 13/20 (auto, 1.51s avg)

  - name: openrouter:free-router
    kind: openrouter
    model: openrouter/free
    api_key_env: OPENROUTER_API_KEY
    rpm: 20
    rpd: 1000
    timeout: 180   # high variance: default bench 12-96s
    tools: false   # auto-роутинг — может уехать на модель без FC, для агентов небезопасно
    quality: 20   # рулетка: gpt-oss-20b / gemma-3-12b / llama-3.2-3b / ... — берём среднюю
    latency_s: 20.506
    ru: 60        # bench: 12/20 (auto, 9.52s avg)

  # === Pollinations (free, no-auth-required legacy API) ===
  # text.pollinations.ai anonymous tier: только `openai-fast` = GPT-OSS 20B Reasoning (OVH backend).
  # Та же модель что groq:gpt-oss-20b, но другой хостер → полезно как backup когда Groq 429.
  # Rate limit: 1 req / 15s = 4 rpm (жёсткий). API ключ не обязателен, но мы шлём наш для consistency
  # с image-провайдером; tier всё равно anonymous (upgrade требует enter.pollinations.ai).
  # Бенч 2026-04-22: ~4s на RU-ответ с max_tokens=800. Reasoning-heavy → короткий max_tokens съедается
  # на thinking; ставим ru=33 (как у groq:gpt-oss-20b — та же модель).

  - name: pollinations:gpt-oss-20b
    kind: pollinations
    model: openai-fast
    api_key_env: POLLINATIONS_API_KEY
    rpm: 4        # 1 req / 15s anonymous
    rpd: 1000     # консервативный soft-cap (теоретически 4 × 60 × 24 = 5760)
    timeout: 120  # reasoning может думать долго
    quality: 25   # AA Index v4.0 (~ groq:gpt-oss-20b, та же GPT-OSS 20B)
    latency_s: 4.0   # измерено 2026-04-22, unique RU prompt, max_tokens=800
    ru: 75        # bench: 15/20 (auto, 24.24s avg)
    reasoning: true   # GPT-OSS 20B Reasoning LLM per Pollinations каталога

