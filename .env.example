# Ключи провайдеров (добавь только те, что будешь использовать)
# Где зарегистрироваться и где взять ключ у каждого — см. docs/providers-setup.md
#
# Multi-key pool: для бесплатных tier'ов где квота per-key (Groq, Gemini, OpenRouter,
# Cohere, GitHub Models) можно класть несколько ключей через запятую и в config.yaml
# заменять `api_key_env: X` на `api_keys_env: X_POOL`. Имя провайдера разворачивается в
# <name>#1 / <name>#2 / ... — каждый суффикс получает свой ключ. См. config.yaml.example.
# Пример:  GROQ_API_KEYS=gsk_aaa,gsk_bbb,gsk_ccc
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
ZAI_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
GITHUB_MODELS_TOKEN=
MISTRAL_API_KEY=
# DeepSeek direct API (api.deepseek.com). 5M токенов кредитов на регистрацию,
# дальше PAYG ($0.28/$0.42 за 1M на V3.2). Off-peak 50-75% скидка 16:30-00:30 UTC.
# Регистрация: platform.deepseek.com → API Keys. $2 топ-ап = месяцы работы.
DEEPSEEK_API_KEY=
# Alibaba DashScope International (Qwen flagship). 1M токенов бесплатно на модель.
# Регистрация: bailian.console.alibabacloud.com через Alibaba Cloud International.
# qwen3.6-plus / qwen3.6-max-preview / qwen3-coder-480b — 1M context.
DASHSCOPE_API_KEY=
# Poolside direct API (inference.poolside.ai). Кодинг-модели Laguna M.1 (225B-A23B
# MoE, SWE-Pro 46.9% / SWE-V 72.5%) и Laguna XS.2 (33B-A3B Apache 2.0). OpenAI-compat.
# Free всем на ограниченное время. Регистрация: platform.poolside.ai → API keys.
POOLSIDE_API_KEY=
# Cohere v2 chat (Command-A / c4ai-aya для русского). 20 RPM, 1000 calls/мес.
# Регистрация: dashboard.cohere.com → API Keys → Trial Key.
# ToS — non-commercial only на free tier.
COHERE_API_KEY=
# HuggingFace Inference Providers Router (OpenAI-compat).
# Регистрация: huggingface.co → Settings → Access Tokens → Read.
# Free tier: ~$0.10/мес общий кредит на все paid sub-providers (Novita/Cerebras/...).
# PRO ($9/мес) = $2 кредит. Модель указывается как "<repo>:<provider>".
HF_TOKEN=
# GigaChat (Sber) — Authorization key (Basic = base64(client_id:client_secret))
# Регистрация: developers.sber.ru → Личное пространство → Мой GigaChat API → Получить новый ключ.
# scope=GIGACHAT_API_PERS (free personal: 1M токенов/30 дней).
GIGACHAT_AUTH_KEY=
# FreeTheAi (api.freetheai.xyz) — OpenAI-compat, ~16k aliases. 10 RPM, 1 concurrent.
# ⚠️ Требует daily Discord /checkin (https://discord.gg/secrets → /signup → /checkin).
# Без чек-ина все запросы возвращают HTTP 403 daily_checkin_required.
# Автоматизировать НЕЛЬЗЯ (Discord ToS). Подробности: docs/providers-setup.md.
FREETHEAI_API_KEY=

# OpenAI — нужен ТОЛЬКО для бесплатной модерации (omni-moderation-latest text+image
# и text-moderation-latest text-only). Сами модели $0, но платформа требует $5
# единоразового депозита, без него все запросы режутся 429-м (включая модерацию).
# Auto-recharge на странице оплаты обязательно ВЫКЛЮЧИТЬ.
# Регистрация: platform.openai.com → API keys → Create new secret key.
# Подробности: docs/providers-setup.md → «OpenAI direct».
OPENAI_API_KEY=
# Тот же $5-аккаунт используется как paid-fallback для gpt-5-mini в `paid` chain.
# Можно вписать тот же ключ что и OPENAI_API_KEY — разделение нужно лишь чтобы
# случайно не сжечь baseline-баланс на paid-вызовах. Если paid-цепочка не нужна
# — оставить пустым, gpt-5-mini автоматически выпадет из chain.
OPENAI_API_KEY_PAID=

# Настройки сервера
NEUROGATE_HOST=127.0.0.1
NEUROGATE_PORT=8765
NEUROGATE_CONFIG=config.yaml

# Опциональный Bearer-токен для защиты API (если пусто — без авторизации)
NEUROGATE_API_TOKEN=

# Уровень логов
LOG_LEVEL=INFO

# Имя "виртуальной модели" для OpenAI-клиентов. Клиент может прислать model="auto"
# и получит ответ от любого доступного провайдера цепочки.
NEUROGATE_VIRTUAL_MODEL=auto
